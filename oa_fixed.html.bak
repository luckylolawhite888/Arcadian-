      <div class="settings-card">
        <div class="sc-head">Shop Profile</div>
        <div class="sc-field">
          <div class="field" style="margin-bottom:10px;"><label>Shop Name</label><input class="inp-full" value="The Coffee Spot"></div>
          <div class="field" style="margin-bottom:10px;"><label>Category</label><select class="inp-full"><option>Coffee</option><option>Food</option><option>Beauty</option><option>Barber</option><option>Retail</option><option>Fitness</option><option>Bar</option></select></div>
