function renderAnalytics() {
  const bars = [
    {label:'Pastry Deal',views:47,conv:6},{label:'Muffin 30%',views:83,conv:14},{label:'Free Tea',views:21,conv:3},{label:'Cake Slice',views:61,conv:9},
  ];
  document.getElementById('analytics-bars').innerHTML = bars.map(b=>`
    <div class="bc-row"><div class="bc-label" style="font-size:10px;">${b.label}</div><div class="bc-bar-bg"><div class="bc-bar-fill" style="width:${b.views/83*100}%"></div></div><div class="bc-num">${b.views}</div></div>`).join('');
}

// ══════════════════════════════════════════════════════
// SCANNER
// ══════════════════════════════════════════════════════
function simulateScan() {
  const el = document.getElementById('scan-result');
  el.style.display = 'block';
  toast('✅ Voucher OAB-2847-0000 redeemed!');
}

// ══════════════════════════════════════════════════════
// MODAL
// ══════════════════════════════════════════════════════
function openModal(title, body) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').innerHTML = body;
  document.getElementById('modal-overlay').classList.add('show');
}
function closeModal() { document.getElementById('modal-overlay').classList.remove('show'); }

// ══════════════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════════════
let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2400);
}

// ══════════════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════════════
function fmtSecs(s) {
  const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=s%60;
  return h>0?`${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`:`${m}:${String(sec).padStart(2,'0')}`;
}

function toggleEl(el) { el.classList.toggle('on'); }


// ══════════════════════════════════════════════════════
// DO_SETUP
// ══════════════════════════════════════════════════════
async function loadDealsFromDB() {
  try {
    let data = await sbFetch('/rest/v1/deals?select=*,stores(name,slug,address,category,lat,lng)&is_published=eq.true&order=created_at.desc');
    if (!data || !data.length) { data = SEED_DEALS; }
    DEALS = data.map((d,idx) => {
      const s = d.stores || {};
      const end = d.end_time || new Date(Date.now()+86400000).toISOString();
      return {
        id: typeof d.id === 'number' ? d.id : idx,
        emoji: _catEm[s.category] || '🛍️',
        bg: _hashBg(d.store_id),
        title: d.title || 'Deal',
        shop: s.name || 'Shop',
        addr: s.address || '',
        cat: s.category || '',
        type: _tl[(d.deal_type||'').toLowerCase()] || d.deal_type || 'Ongoing',
        desc: d.description || '',
        dist: _dist(s.lat, s.lng),
        price: Number(d.discount_price||0),
        priceLabel: _pl(d),
        timerSecs: _ts(end),
        stock: Math.max(0, (d.daily_limit||0) - (d.redeemed_count||0)),
        totalStock: d.daily_limit||0,
        urgency: _urg(end),
        lateNight: false,
        redemptions: d.redeemed_count||0,
        views: Math.floor(Math.random()*50),
        store_id: d.store_id,
        original_price: d.original_price,
        discount_percent: d.discount_percent,
        end_time: end
      };
    });
    timerSecs = DEALS.map(d => d.timerSecs);
  } catch(e) {
    console.error('loadDeals:', e);
    // Fallback to seed data
    DEALS = SEED_DEALS.map((d,idx) => ({...d, id: idx}));
    timerSecs = DEALS.map(d => d.timerSecs);
  }
}

async function startApp() {
  await checkSession();
  await loadDealsFromDB();
  renderAlerts();
  renderSaved();
  renderProfile();
  renderFeed();
  renderShopDash();
  renderShopDeals();
  // Attach image upload handler (re-attaches after DOM rebuilds)
  document.addEventListener('change', function(e) {
    if (e.target && e.target.id === 'img-file-input') {
      handleImageFile(e);
    }
  });
  // Start timer tick
  setInterval(() => {
    DEALS.forEach((d,i) => { 
      if(d.end_time) {
        const oldSecs = timerSecs[i];
        timerSecs[i] = _ts(d.end_time);
        // Push notification if ending soon (60s or less) and just crossed threshold
        if (oldSecs && timerSecs[i] <= 60 && oldSecs > 60 && Notification.permission === 'granted') {
          new Notification('⏰ Deal Ending Soon!', { body: d.title + ' at ' + d.shop, icon: '/favicon.ico' });
        }
      }
    });
    const feed = document.getElementById('deal-feed');
    if (feed && feed.innerHTML) renderFeed();
  }, 5000);
}


// ══════════════════════════════════════════════════════
// SHARE & MAPS
// ══════════════════════════════════════════════════════
function viewShopDeals(shop) {
  window._shopFilter = shop;
  // Apply filter to the main feed
  const el = document.getElementById('deal-feed');
  const filtered = DEALS.filter(d => d.shop === shop);
  let html = '<div class="sec-lbl">🏪 All deals at ' + shop + '</div>';
  filtered.forEach(d => html += dealCardHTML(d));
  html += '<button class="btn-outline" style="margin:16px;" onclick="window._shopFilter=null;renderFeed();showFilterBar();">← Back to all deals</button>';
  el.innerHTML = html;
}

function shareDeal(id) {
  var d = _findDeal(id);
  if (!d) return;
  const text = `🎉 Check out this deal: ${d.title} at ${d.shop}!\n\n${d.desc}\n\n${d.priceLabel} — grab it on Out & About!`;
  if (navigator.share) {
    navigator.share({ title: d.title, text, url: window.location.href }).catch(() => {});
  } else {
    navigator.clipboard.writeText(text).then(() => toast('📋 Copied! Share via WhatsApp/iMessage'));
    const waUrl = 'https://wa.me/?text=' + encodeURIComponent(text);
    window.open(waUrl, '_blank');
  }
}

function translateDeal(id) {
  var d = _findDeal(id);
  if (!d) return;
  const userLang = navigator.language || navigator.userLanguage || 'en';
  const targetLang = userLang.split('-')[0];
  const text = d.title + '\n\n' + d.desc;
  const url = 'https://translate.google.com/?sl=auto&tl=' + targetLang + '&text=' + encodeURIComponent(text) + '&op=translate';
  window.open(url, '_blank');
  toast('🌐 Translating to ' + userLang);
}

function openMaps(id) {
  var d = _findDeal(id);
  if (!d) return;
  const query = encodeURIComponent(d.title + ' ' + d.shop + ' ' + (d.addr || ''));
  const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=' + query;
  window.open(mapsUrl, '_blank');
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => startApp());
} else {
  startApp();
}
</script>
</body>
</html>

// ══════════════════════════════════════════════════════
// QR SCANNER (real camera via getUserMedia)
// ══════════════════════════════════════════════════════
let scannerStream = null;
let scanTimer = null;
function startScanner() {
  var video = document.getElementById('scanner-video');
  var ph = document.getElementById('scanner-placeholder');
  var btn = document.getElementById('scan-start-btn');
  var canvas = document.getElementById('scanner-canvas');
  console.log('[Scanner] startScanner called', {video:!!video, ph:!!ph, btn:!!btn, canvas:!!canvas});
  if (!video || !ph) { toast('❌ Scanner elements not found'); console.error('[Scanner] Missing DOM elements'); return; }
  if (btn) btn.textContent = '📷 Starting camera...';
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    toast('❌ Camera not supported on this device/browser');
    console.error('[Scanner] getUserMedia not available');
    if (btn) btn.textContent = '📷 Camera Unavailable';
    return;
  }
  navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 480 } } })
    .then(function(stream) {
      scannerStream = stream;
      video.srcObject = stream;
      video.style.display = 'block';
      ph.style.display = 'none';
      if (btn) btn.textContent = '📷 Camera Active';
      toast('📷 Point camera at QR code');
      console.log('[Scanner] Camera started successfully');
      // Start QR scanning loop
      scanTimer = setInterval(scanQRFrame, 300);
    })
    .catch(function(err) {
      console.error('[Scanner] Camera error:', err.name, err.message);
      toast('Camera: ' + err.message + '. Try Simulate Scan instead.');
      if (btn) btn.textContent = '📷 Start Camera';
    });
}

function scanQRFrame() {
  var video = document.getElementById('scanner-video');
  if (!video || video.readyState < 2) return;
  if (document.getElementById('scan-result').style.display === 'block') return;
  var canvas = document.getElementById('scanner-canvas');
  if (!canvas) { console.error('[Scanner] canvas element missing'); return; }
  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;
  var ctx = canvas.getContext('2d');
  if (!ctx) { console.error('[Scanner] could not get 2d context'); return; }
  ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
  var imageData = null;
  try {
    imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
  } catch(e) { console.error('[Scanner] getImageData error:', e.message); return; }
  // jsQR from CDN
  if (typeof jsQR === 'function') {
    var code = jsQR(imageData.data, imageData.width, imageData.height);
    if (code && code.data) {
      console.log('[Scanner] QR code detected:', code.data.substring(0,20));
      handleQRCode(code.data);
    }
  } else {
    console.warn('[Scanner] jsQR not loaded');
  }
}

function handleQRCode(data) {
  // Stop scanning
  clearInterval(scanTimer);
  stopScanner();
  // Parse the QR data - expected format: voucher code or deal reference
  const code = data.trim();
  if (!code) { toast('❌ Empty QR code'); startScanner(); return; }
  // Check if this code matches a known voucher/deal
  const foundDeal = SHOP_DEALS.find(d => d.id == code || d.voucherCode == code);
  const dealName = foundDeal ? foundDeal.title : 'Voucher';
  // Show redemption success
  const result = document.getElementById('scan-result');
  document.getElementById('scan-result-detail').innerHTML = dealName + '<br>Code: ' + code.substring(0,12);
  result.style.display = 'block';
  // Auto-close after 5s
  setTimeout(() => { result.style.display = 'none'; startScanner(); }, 5000);
}

function stopScanner() {
  if (scanTimer) { clearInterval(scanTimer); scanTimer = null; }
  if (scannerStream) {
    scannerStream.getTracks().forEach(t => t.stop());
    scannerStream = null;
  }
  const video = document.getElementById('scanner-video');
  if (video) video.style.display = 'none';
  const ph = document.getElementById('scanner-placeholder');
  if (ph) ph.style.display = 'flex';
  const btn = document.getElementById('scan-start-btn');
  if (btn) btn.textContent = '📷 Start Camera';
}

// Update simulateScan to use same success flow
function simulateScan() {
  handleQRCode('OAB-' + Date.now().toString(36).toUpperCase());
}

// ══════════════════════════════════════════════════════
// CANCEL/END A DEAL (shop can end a deal anytime)
// ══════════════════════════════════════════════════════
function endDeal(dealId) {
  // Find in SHOP_DEALS
  const idx = SHOP_DEALS.findIndex(d => d.id === dealId || ('new'+d.id) === dealId);
  if (idx >= 0) {
    SHOP_DEALS[idx].status = 'expired';
    SHOP_DEALS[idx].remaining = 0;
    renderShopDeals();
    toast('⛔ Deal ended — no longer available');
  }
  // Also remove from main DEALS
  const mainIdx = DEALS.findIndex(d => d.id === dealId || d.id === 'new'+dealId);
  if (mainIdx >= 0) {
    DEALS.splice(mainIdx, 1);
    timerSecs.splice(mainIdx, 1);
    renderFeed();
  }
}

