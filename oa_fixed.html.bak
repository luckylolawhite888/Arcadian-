<script>
// ══════════════════════════════════════════════════════
// DATA
// ══════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════
// SUPABASE CONFIG
// ══════════════════════════════════════════════════════
const SUPABASE_URL = 'https://mdleurcenwmmenvkwjhl.supabase.co';
const SUPABASE_ANON_KEY = 'sb_publishable_mPjat_GLHfK1TwzPxEa2tQ_OvutOgDL';
const _supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

function sbFetch(path, opts={}) {
  const h = {'apikey':SUPABASE_ANON_KEY,'Authorization':'Bearer '+SUPABASE_ANON_KEY,'Content-Type':'application/json','Prefer':'return=representation',...opts.headers};
  return fetch(SUPABASE_URL+path,{...opts,headers:h}).then(r=>{if(!r.ok)throw r;return r.json()});
}
const _catEm = {'Coffee':'☕','Food':'🍕','Barber':'✂️','Beauty':'💆','Retail':'👟','Bar':'🍺','Fitness':'💪'};
function _hashBg(s){if(!s)return '#1a0f00';let h=0;for(let c of s)h=((h<<5)-h)+c.charCodeAt(0);return ['#1a0f00','#0a1a0a','#0d0d1a','#1a0a0a','#0a0d1a','#0d1a0a','#1a1a0a'][Math.abs(h)%7];}
function _dist(sl,sl2){if(!sl||!sl2)return'0.5mi';let d=Math.sqrt(Math.pow((51.53-sl)*69,2)+Math.pow((-0.248-sl2)*52,2));return d<1?Math.round(d*10)/10+'mi':Math.round(d)+'mi';}
const _tl = {flash_sale:'Flash Sale',end_of_day:'End of Day',happy_hour:'Happy Hour',ongoing:'Ongoing'};
function _pl(d){if(d.discount_percent===100||(d.discount_price===0&&d.discount_percent))return'FREE';if(d.discount_price)return'£'+Number(d.discount_price).toFixed(0);if(d.discount_percent)return d.discount_percent+'% OFF';return'OFFER';}
function _ts(end){return Math.max(0,Math.floor((new Date(end).getTime()-Date.now())/1000));}
function _urg(end){const s=_ts(end);return s<3600?'high':s<14400?'medium':'low';}

let DEALS = [];
let timerSecs = [];
// Fallback seed deals if database is empty
const SEED_DEALS = [
  { id:0,emoji:'☕',bg:'linear-gradient(135deg,#a0522d,#8B4513)',title:'Free Pastry with Coffee',shop:'Brew & Bean',addr:'24 Market St, NW1',cat:'Coffee',type:'Freebie',desc:'Get a free pastry when you buy any large coffee. Freshly baked croissants, muffins, and danishes available!',dist:'0.3 mi',price:0,priceLabel:'FREE',timerSecs:36000,stock:18,totalStock:20,urgency:'low',redemptions:2,views:45,store_id:1,end_time:new Date(Date.now()+36000000).toISOString() },
  { id:1,emoji:'✂️',bg:'linear-gradient(135deg,#c0392b,#e74c3c)',title:'50% Off First Cut',shop:"Gentleman's Groom",addr:"10 King's Rd, SW3",cat:'Barber',type:'50% Off',desc:'Half price on your first haircut with us. Top-rated barbers in the area, walk-ins welcome!',dist:'0.7 mi',price:0,priceLabel:'50% OFF',timerSecs:72000,stock:9,totalStock:15,urgency:'medium',redemptions:6,views:78,store_id:2,end_time:new Date(Date.now()+72000000).toISOString() },
  { id:2,emoji:'🍕',bg:'linear-gradient(135deg,#d4a017,#b8860b)',title:'Buy 1 Get 1 Free Pizza',shop:'Napoli Slice',addr:'42 Oxford St, W1',cat:'Food',type:'BOGO',desc:'Buy any large pizza, get a second one free! Dine-in or takeaway. Valid on all our signature pizzas.',dist:'0.5 mi',price:0,priceLabel:'BOGO',timerSecs:14400,stock:3,totalStock:10,urgency:'high',redemptions:7,views:120,store_id:3,end_time:new Date(Date.now()+14400000).toISOString() },
  { id:3,emoji:'💆',bg:'linear-gradient(135deg,#8e44ad,#9b59b6)',title:'30% Off Full Body Massage',shop:'Serenity Spa',addr:'8 Baker St, W1',cat:'Beauty',type:'30% Off',desc:'Enjoy a 60-minute full body massage at 30% off. Perfect for winding down after a long week. Bookings essential.',dist:'1.2 mi',price:35,priceLabel:'£35',timerSecs:108000,stock:5,totalStock:8,urgency:'low',redemptions:3,views:67,store_id:4,end_time:new Date(Date.now()+108000000).toISOString() },
  { id:4,emoji:'👟',bg:'linear-gradient(135deg,#2c3e50,#34495e)',title:'20% Off All Trainers',shop:'Sole Mates',addr:'15 Camden High St, NW1',cat:'Retail',type:'20% Off',desc:'20% off all trainers and sneakers. Nike, Adidas, New Balance — huge selection in-store!',dist:'0.8 mi',price:0,priceLabel:'20% OFF',timerSecs:172800,stock:40,totalStock:50,urgency:'low',redemptions:10,views:89,store_id:5,end_time:new Date(Date.now()+172800000).toISOString() },
];const SHOP_DEALS = [
  {id:'s1',emoji:'☕',title:'Free Pastry with Any Coffee',type:'Flash Sale',status:'live',views:47,walkins:6,remaining:12,total:20},
  {id:'s2',emoji:'🥐',title:'Morning Muffin 30% Off',type:'End of Day',status:'half',views:83,walkins:14,remaining:4,total:20},
  {id:'s3',emoji:'🍵',title:'Loyalty Free Tea',type:'Ongoing',status:'live',views:21,walkins:3,remaining:9,total:10},
  {id:'s4',emoji:'🎂',title:'Birthday Cake Slice Deal',type:'Flash Sale',status:'expired',views:61,walkins:9,remaining:0,total:15},
];

const ALERTS_DATA = [
  {icon:'☕',bg:'rgba(255,92,0,.1)',title:'Free pastry at The Coffee Spot!',body:'You walked past — free pastry with any coffee. 47 mins left.',time:'2m ago',unread:true,dealId:0},
  {icon:'✂️',bg:'rgba(245,197,24,.1)',title:'Flash sale: 50% off haircuts',body:'Blades Barbers — 1 hour 12 mins left.',time:'8m ago',unread:true,dealId:1},
  {icon:'🍕',bg:'rgba(74,158,255,.1)',title:'Slice & Dice: Buy 1 Get 1',body:'Happy hour at your followed shop — 3h 45m left.',time:'24m ago',unread:false,dealId:2},
  {icon:'💆',bg:'rgba(46,204,113,.1)',title:'30% off beauty treatments',body:'Serenity Beauty has a new deal.',time:'1h ago',unread:false,dealId:3},
  {icon:'🍺',bg:'rgba(74,158,255,.1)',title:'2-4-1 Cocktails tonight',body:'The Barrel House — happy hour from 5pm.',time:'2h ago',unread:false,dealId:5},
];

// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
let currentScreen = 's-splash';
let prevScreen = 's-home';
let savedDeals = new Set();
let followedShops = new Set();
let userMode = 'consumer'; // 'consumer' | 'shop'
let nightOwl = false;
let catFilter = 'all';
let typeFilter = 'all';
let currentDealId = 0;
timerSecs = DEALS.map(d => d.timerSecs);
let createStep = 1;
let createData = {};
let aiIdx = 0;
let loggedIn = false;
let userName = '';

const AI_DESCS = [
  "Treat yourself today! Get a FREE pastry with any coffee order. Our fresh croissants and muffins are baked daily — pop in before stocks run out. Today only! ☕🥐",
  "Flash deal alert! Any coffee drink comes with a complimentary pastry — on the house. No minimum spend, just show the app at the counter. 🙌",
  "Good morning deal! We're giving away free pastries with every coffee this morning. Perfect way to start your day — while stocks last! ⚡",
];

// ══════════════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════════════
function goScreen(id) {
  const prev = document.getElementById(currentScreen);
  if (prev) prev.classList.remove('active');
  prevScreen = currentScreen;
  currentScreen = id;
  const next = document.getElementById(id);
  if (next) next.classList.add('active');
  const shell = document.getElementById('app-shell');
  shell.scrollTop = 0;
}

function goConsumer(id) { goScreen(id); if(id==='s-saved')renderSaved(); if(id==='s-profile')renderProfile(); if(id==='s-alerts')renderAlerts(); if(id==='s-map')renderMapList(); }
function goShop(id) { 
  if(currentScreen==='s-shop-scanner'&&id!=='s-shop-scanner')stopScanner(); 
  goScreen(id); 
  if(id==='s-shop-deals')renderShopDeals(); 
  if(id==='s-shop-dash')renderShopDash(); 
  if(id==='s-shop-analytics')renderAnalytics(); 
  if(id==='s-shop-create'){createStep=1;renderCreateStep();} 
  if(id==='s-shop-scanner')setTimeout(startScanner,500);
}
function goBack() {
  // Never loop back into s-detail or s-qr from themselves
  const safe = ['s-home','s-map','s-saved','s-alerts','s-profile','s-splash',
                 's-shop-dash','s-shop-deals','s-shop-create','s-shop-analytics','s-shop-settings','s-shop-success'];
  if (safe.includes(prevScreen)) {
    goScreen(prevScreen);
  } else {
    // Fall back to home or shop dash depending on context
    const shopScreens = ['s-shop-dash','s-shop-deals','s-shop-create','s-shop-analytics','s-shop-settings','s-shop-qr','s-shop-success'];
    if (shopScreens.includes(currentScreen)) goScreen('s-shop-dash');
    else goScreen('s-home');
  }
}
function showSplash() { goScreen('s-splash'); }

// ══════════════════════════════════════════════════════
// AUTH
// ══════════════════════════════════════════════════════
async function checkSession() {
  // Request push notification permission
  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
  }
  try {
    const { data: { session } } = await _supabase.auth.getSession();
    if (session) {
      loggedIn = true; userId = session.user.id; userEmail = session.user.email || '';
      userName = session.user.user_metadata?.name || userEmail.split('@')[0];
      userRole = session.user.user_metadata?.role || 'consumer';
    }
  } catch(e) {
    console.error('Session check failed (OK for offline):', e);
  }
  try {
    const {data:{session}} = await _supabase.auth.getSession();
    if (session) {
      loggedIn = true; userId = session.user.id; userEmail = session.user.email || '';
      userName = session.user.user_metadata?.name || userEmail.split('@')[0];
      userRole = session.user.user_metadata?.role || 'consumer';
    }
  } catch(e) { console.error('Session check:', e); }
}

function doLogin() {
  const email = document.getElementById('li-email')?.value?.trim();
  const pass = document.getElementById('li-pass')?.value;
  if (!email || !pass) { toast('⚠️ Fill in all fields'); return; }
  _supabase.auth.signInWithPassword({email,password:pass}).then(({error, data})=>{
    if (error) { toast('❌ '+error.message); return; }
    // Check role from user metadata
    const meta = data?.user?.user_metadata || {};
    if (meta.role === 'shop') {
      toast('✅ Welcome back, shop!');
      goShop('s-shop-dash');
    } else {
      toast('✅ Welcome back!');
      goConsumer('s-home');
    }
  });
}

function doRegister() {
  const name = document.getElementById('reg-name')?.value?.trim() || document.getElementById('reg-shop-name')?.value?.trim();
  const email = document.getElementById('reg-email')?.value?.trim() || document.getElementById('reg-shop-email')?.value?.trim();
  const phone = document.getElementById('reg-phone')?.value?.trim() || document.getElementById('reg-shop-phone')?.value?.trim();
  const pass = document.getElementById('reg-pass')?.value || document.getElementById('reg-shop-pass')?.value;
  if (!name || !email || !pass) { toast('⚠️ Fill in all fields'); return; }
  if (pass.length < 6) { toast('⚠️ Password must be 6+ characters'); return; }
  if (phone && phone.length < 10) { toast('⚠️ Enter a valid phone number'); return; }
  const role = loginMode === 'shop' ? 'shop' : 'consumer';
  _supabase.auth.signUp({email,password:pass,options:{data:{name,role,phone}}}).then(({error: signupErr, data: signupData})=>{
    if (signupErr) {
      toast('❌ '+signupErr.message);
      return;
    }
    // Auto confirm if email confirmation disabled, else show message
    if (signupData?.user?.identities?.length) {
      toast('✅ Account created! Signing in...');
      _supabase.auth.signInWithPassword({email,password:pass}).then(({error: loginErr, data: loginData})=>{
        if (loginErr) toast('⚠️ Created but auto-login failed: '+loginErr.message);
        else {
          const meta = loginData?.user?.user_metadata || {};
          toast('✅ Welcome!');
          if (meta.role === 'shop') goShop('s-shop-dash');
          else goConsumer('s-home');
        }
      });
    } else {
      toast('✅ Check your email to confirm!');
    }
  });
}

function doLogout() {
  _supabase.auth.signOut().then(()=>{
    loggedIn = false; userId = null; userName = ''; userEmail = ''; userRole = 'consumer';
    toast('👋 Logged out');
  });
}

_supabase.auth.onAuthStateChange((event, session) => {
  if (event === 'SIGNED_IN' && session) {
    loggedIn = true; userId = session.user.id; userEmail = session.user.email || '';
    userName = session.user.user_metadata?.name || userEmail.split('@')[0];
    userRole = session.user.user_metadata?.role || 'consumer';
    // If already on consumer home but user is shop, redirect
    if (userRole === 'shop' && currentScreen === 's-home') {
      setTimeout(() => goShop('s-shop-dash'), 100);
    }
  } else if (event === 'SIGNED_OUT') {
    loggedIn = false; userId = null; userName = ''; userEmail = ''; userRole = 'consumer';
  }
});
function showLogin(mode) {
  loginMode = mode;
  document.getElementById('login-sub-text').textContent = mode === 'shop' ? 'Shop owner portal' : 'Welcome back';
  document.getElementById('reg-consumer-fields').style.display = mode === 'shop' ? 'none' : 'block';
  document.getElementById('reg-shop-fields').style.display = mode === 'shop' ? 'block' : 'none';
  goScreen('s-login');
}

function switchAuthTab(tab) {
  document.getElementById('tab-login').classList.toggle('active', tab==='login');
  document.getElementById('tab-register').classList.toggle('active', tab==='register');
  document.getElementById('auth-login').style.display = tab==='login' ? 'block' : 'none';
  document.getElementById('auth-register').style.display = tab==='register' ? 'block' : 'none';
}


// ══════════════════════════════════════════════════════
// DEAL FEED
// ══════════════════════════════════════════════════════
function filteredDeals() {
  return DEALS.filter(d => {
    if (nightOwl && !d.lateNight) return false;
    if (catFilter !== 'all' && d.cat !== catFilter) return false;
    if (typeFilter !== 'all' && d.type !== typeFilter) return false;
    return true;
  });
}

function renderFeed() {
  const feed = document.getElementById('deal-feed');
  const deals = filteredDeals();
  if (!deals.length) {
    feed.innerHTML = '<div class="empty-state"><div class="es-icon">🔍</div><div class="es-title">No deals found</div><div class="es-desc">Try adjusting your filters or check back later.</div></div>';
    return;
  }
  const urgentDeals = deals.filter(d => d.urgency === 'high' || d.urgency === 'medium');
  const otherDeals = deals.filter(d => d.urgency === 'low');
  let html = '';
  if (urgentDeals.length) { html += '<div class="sec-lbl">🔴 Ending Soon</div>'; urgentDeals.forEach(d => html += dealCardHTML(d)); }
  if (otherDeals.length) { html += '<div class="sec-lbl">📍 Near You</div>'; otherDeals.forEach(d => html += dealCardHTML(d)); }
  html += '<div style="height:16px;"></div>';
  feed.innerHTML = html;
}

function dealCardHTML(d) {
  const isSaved = savedDeals.has(d.id);
  const tc = d.urgency==='high' ? 'var(--red)' : d.urgency==='medium' ? 'var(--yellow)' : 'var(--green)';
  const tagClass = d.urgency==='high' ? 'tag-red' : d.urgency==='medium' ? 'tag-yellow' : 'tag-green';
  const secs = d.timerSecs || _ts(d.end_time) || 86400;
  // Use uploaded image if available
  var cardBg = d.bg;
  console.log('[Card] deal:', d.title, 'images:', d.images ? d.images.length + ' items' : 'none');
  if (d.images && d.images[0] && d.images[0].length > 50) {
    console.log('[Card] using image', d.images[0].substring(0,30) + '...');
    cardBg = 'url(' + d.images[0] + ') center/cover no-repeat';
  }
  var cardEmoji = (d.images && d.images[0] && d.images[0].length > 50) ? '' : d.emoji;
  return `<div class="deal-card" onclick="openDeal('${d.id}')">
    <div class="deal-card-img" style="background:${cardBg};${d.images && d.images[0] && d.images[0].length > 50 ? 'background-size:cover;' : ''}">
      <span style="font-size:52px;">${cardEmoji}</span>
      <div class="deal-tag ${tagClass}">${d.urgency==='high'?'🔴 Ends Soon':d.type}</div>
      <div class="deal-price-badge">${d.priceLabel}</div>
      <button class="fav-btn" onclick="toggleFav(event,'${d.id}')">${isSaved?'❤️':'🤍'}</button>
    </div>
    <div class="deal-body">
      <div class="deal-row1"><div class="deal-title">${d.title}</div><div class="deal-dist">${d.dist}</div></div>
      <div class="deal-shop">${d.emoji} ${d.shop}</div>
      <div class="deal-foot">
        <span class="deal-timer" style="color:${tc}">⏱ ${fmtSecs(secs)}</span>
        <button class="share-sm" onclick="event.stopPropagation();shareDeal(d.id)">💬 Share</button>
      </div>
    </div>
  </div>`;
}

function selFilter(el, cat) {
  document.querySelectorAll('#cat-filters .chip').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  catFilter = cat;
  renderFeed();
}

function selTypeFilter(el, type) {
  document.querySelectorAll('#type-filters .chip').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  typeFilter = type;
  renderFeed();
}

function toggleNight() {
  nightOwl = !nightOwl;
  document.getElementById('night-tog').classList.toggle('on', nightOwl);
  renderFeed();
}

// ══════════════════════════════════════════════════════
// DEAL DETAIL
// ══════════════════════════════════════════════════════

// Safe deal lookup by id (supports both array index and string ID)
function _findDeal(id) {
  if (id === undefined || id === null) return null;
  // First try to match by id field (string IDs from publishDeal or DB IDs)
  for (var i = 0; i < DEALS.length; i++) {
    if (DEALS[i] && (DEALS[i].id === id || String(DEALS[i].id) === String(id) || DEALS[i].id == id)) {
      return DEALS[i];
    }
  }
  // Fallback: try direct array index (for legacy numeric IDs)
  if (typeof id === 'number' && id >= 0 && id < DEALS.length) {
    console.warn('[Deal] Falling back to array index for id:', id);
    return DEALS[id];
  }
  console.warn('[Deal] Deal not found for id:', id);
  return null;
}

function openDeal(id) {
  currentDealId = id;
  // Find deal by unique id
  console.log('[OpenDeal] id:', id);
  var d = _findDeal(id);
  if (!d) { toast('Deal not found'); return; }
  console.log('[OpenDeal] found:', d.title, 'has images:', d.images ? d.images.length : 0);
  document.getElementById('det-hero').style.background = d.bg;
  document.getElementById('det-hero').childNodes[0].nodeValue = d.emoji;
  document.getElementById('det-fav-btn').textContent = savedDeals.has(id) ? '❤️' : '🤍';
  const secs = d.timerSecs || _ts(d.end_time) || 86400;
  const stockPct = (d.stock / d.totalStock * 100).toFixed(0);
  const isSaved = savedDeals.has(id);
  // Build image gallery if deal has images
  var detImgs = '';
  if (d.images) {
    var validImgs = [];
    for (var _di = 0; _di < d.images.length; _di++) {
      if (d.images[_di] && d.images[_di].length > 50) validImgs.push(d.images[_di]);
    }
    if (validImgs.length > 0) {
      detImgs = '<div class="det-img-gallery">';
      for (var _di2 = 0; _di2 < validImgs.length; _di2++) {
        detImgs += '<img src="' + validImgs[_di2] + '" class="det-img" alt="Deal photo" onclick="window.open(\'' + validImgs[_di2] + '\')">';
      }
      detImgs += '</div>';
    }
  }
  let body = detImgs + `
    <div class="det-badges">
      <div class="dbadge db-orange">⚡ ${d.type}</div>
      <div class="dbadge db-blue">📍 ${d.dist}</div>
      ${d.stock <= 3 ? '<div class="dbadge" style="background:rgba(231,76,60,.15);color:var(--red);">🔥 Almost Gone</div>' : ''}
    </div>
    <div class="det-title">${d.title}</div>
    <div class="det-shop">${d.emoji} ${d.shop} · ${d.addr}</div>
    <div class="det-desc">${d.desc}</div>`;
  if (d.type === 'Flash Sale' || d.timerSecs < 21600) {
    body += `<div class="det-timer-card">
      <div><div class="dtc-label">Time Left</div><div class="dtc-val" id="det-timer-val">${fmtSecs(secs)}</div></div>
      <div style="text-align:right;"><div class="dtc-label">Stock</div><div class="dtc-val dtc-green">${d.stock}/${d.totalStock}</div></div>
    </div>`;
  }
  body += `<div style="background:var(--card);border-radius:14px;padding:12px 14px;margin-bottom:14px;">
    <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px;">Availability</div>
    <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="font-size:13px;">${d.stock} remaining of ${d.totalStock}</span><span style="font-size:12px;color:var(--orange);font-weight:700;">${stockPct}%</span></div>
    <div style="height:5px;background:var(--border);border-radius:3px;"><div style="height:100%;width:${stockPct}%;background:var(--orange);border-radius:3px;"></div></div>
  </div>`;
  if (d.price > 0) {
    body += `<div class="det-price">£${d.price.toFixed(2)} <span>pre-paid voucher</span></div>`;
  }
  body += `<div class="det-actions">
    <button class="act-buy" onclick="${d.price > 0 ? `buyVoucher(${id})` : `showQR(${id})`}">${d.price > 0 ? '💳 Buy Now' : '🎟️ Get Free'}</button>
    <button class="act-map" onclick="openMaps(currentDealId)">📍 Open in Maps</button>
  </div>
  <button class="act-redeem" onclick="showRedeemQR(${id})">🎟️ Redeem Voucher</button>
  <button class="act-share-full" onclick="shareDeal(currentDealId)">💬 Tell a Friend</button>
  <button class="act-share-full" style="margin-top:6px;" onclick="translateDeal(currentDealId)">🌐 Translate</button>
  <div class="shop-info">
    <h4>About the shop</h4>
    <div class="shop-row">📍 ${d.addr}</div>
    <div class="shop-row">🕐 Open until 7:00 PM today</div>
    <div class="shop-row">⭐ ${d.views} people viewed · ${d.redemptions} redeemed</div>
    <button class="follow-btn ${followedShops.has(d.shop)?'on':''}" id="follow-btn-det" onclick="toggleFollow('${d.shop}')">
      ${followedShops.has(d.shop)?`✓ Following ${d.shop}`:`+ Follow ${d.shop}`}
    </button>
    <button class="follow-btn" style="margin-top:8px;" onclick="viewShopDeals('${d.shop}')">🏪 View all deals by ${d.shop}</button>
  </div>
  <div style="margin-top:14px;">
    <div style="font-size:13px;font-weight:700;margin-bottom:10px;">Rate this shop</div>
    <div class="stars-row" id="stars-row">
      ${[1,2,3,4,5].map(i=>`<span class="star" onclick="rateDeal(${i})" data-star="${i}">⭐</span>`).join('')}
    </div>
    <div id="rating-thanks" style="font-size:12px;color:var(--muted);display:none;">Thanks for your review!</div>
  </div>
  <div style="height:24px;"></div>`;
  document.getElementById('det-body').innerHTML = body;
  // Always record a real origin screen so back works
  if (!['s-home','s-map','s-saved','s-alerts','s-profile'].includes(currentScreen)) {
    prevScreen = 's-home';
  }
  goScreen('s-detail');
}

function toggleDetFav() {
  const id = currentDealId;
  savedDeals.has(id) ? savedDeals.delete(id) : savedDeals.add(id);
  document.getElementById('det-fav-btn').textContent = savedDeals.has(id) ? '❤️' : '🤍';
  toast(savedDeals.has(id) ? '❤️ Saved!' : 'Removed from saved');
}

function toggleFav(e, id) {
  e.stopPropagation();
  savedDeals.has(id) ? savedDeals.delete(id) : savedDeals.add(id);
  renderFeed();
}

function toggleFollow(shop) {
  followedShops.has(shop) ? followedShops.delete(shop) : followedShops.add(shop);
  const btn = document.getElementById('follow-btn-det');
  if (btn) { btn.textContent = followedShops.has(shop) ? `✓ Following ${shop}` : `+ Follow ${shop}`; btn.classList.toggle('on', followedShops.has(shop)); }
}

function rateDeal(n) {
  if (currentDealId === null || currentDealId === undefined) return;
  document.querySelectorAll('#stars-row .star').forEach((s,i) => s.classList.toggle('lit', i < n));
  document.getElementById('rating-thanks').style.display = 'block';
}

// ══════════════════════════════════════════════════════
// QR / VOUCHER
// ══════════════════════════════════════════════════════
function showQR(id) {
  console.log('[OpenDeal] id:', id);
  var d = _findDeal(id);
  if (!d) { toast('Deal not found'); return; }
  console.log('[OpenDeal] found:', d.title, 'has images:', d.images ? d.images.length : 0);
  document.getElementById('qr-title').textContent = d.title;
  document.getElementById('qr-shop').textContent = d.shop;
  const code = 'OAB-' + Math.floor(1000+Math.random()*9000) + '-' + d.id.toString().padStart(4,'0');
  document.getElementById('qr-code-text').textContent = code;
  generateQRSVG(code);
  goScreen('s-qr');
}

function showRedeemQR(id) {
  console.log('[OpenDeal] id:', id);
  var d = _findDeal(id);
  if (!d) { toast('Deal not found'); return; }
  console.log('[OpenDeal] found:', d.title, 'has images:', d.images ? d.images.length : 0);
  var code = 'OAB-' + Math.floor(1000+Math.random()*9000) + '-' + String(id).padStart(4,'0');
  openModal('Redeem Your Voucher', `
    <div style="text-align:center;padding-bottom:8px;">
      <div style="background:#fff;border-radius:16px;padding:20px;display:inline-block;margin-bottom:16px;">
        <svg id="redeem-qr-svg" width="160" height="160" viewBox="0 0 160 160"></svg>
      </div>
      <div style="font-size:18px;font-weight:800;margin-bottom:4px;">${d.title}</div>
      <div style="font-size:13px;color:var(--muted);margin-bottom:14px;">${d.shop}</div>
      <div style="background:var(--card);border-radius:12px;padding:12px;margin-bottom:16px;">
        <div style="font-family:'DM Mono',monospace;font-size:18px;font-weight:500;color:var(--orange);letter-spacing:2px;">${code}</div>
      </div>
      <div style="background:rgba(46,204,113,.08);border:1px solid rgba(46,204,113,.3);border-radius:12px;padding:14px;text-align:left;">
        <div style="font-size:13px;font-weight:700;color:var(--green);margin-bottom:6px;">✅ How to redeem</div>
        <div style="font-size:13px;color:var(--muted);line-height:1.7;">1. Show this QR code to the shop staff<br>2. They scan it with their Out &amp; About shop app<br>3. Done — enjoy your deal! 🎉</div>
      </div>
    </div>
  `);
  // Generate QR after modal opens
  setTimeout(() => {
    const svg = document.getElementById('redeem-qr-svg');
    if (svg) {
      const size=160,modules=21,mod=size/modules;
      let paths = '<rect width="160" height="160" fill="white" rx="8"/>';
      const pattern=[];
      for(let r=0;r<modules;r++){pattern[r]=[];for(let c=0;c<modules;c++){
        const inPos=(r<7&&c<7)||(r<7&&c>=modules-7)||(r>=modules-7&&c<7);
        const border=(r===0||r===6||r===modules-1||r===modules-7)&&inPos;
        const inner=(r>=2&&r<=4&&c>=2&&c<=4)||(r>=2&&r<=4&&c>=modules-5&&c<=modules-3)||(r>=modules-5&&r<=modules-3&&c>=2&&c<=4);
        pattern[r][c]=border||inner||(Math.abs(code.charCodeAt((r*modules+c)%code.length)%3)===0);
      }}
      for(let r=0;r<modules;r++)for(let c=0;c<modules;c++){
        if(pattern[r][c])paths+=`<rect x="${c*mod+1}" y="${r*mod+1}" width="${mod-1}" height="${mod-1}" fill="#111" rx="1"/>`;
      }
      svg.innerHTML=paths;
    }
  }, 50);
}

function buyVoucher(id) {
  console.log('[OpenDeal] id:', id);
  var d = _findDeal(id);
  if (!d) { toast('Deal not found'); return; }
  console.log('[OpenDeal] found:', d.title, 'has images:', d.images ? d.images.length : 0);
  openModal('Complete Purchase', `
    <div style="background:var(--card);border-radius:14px;padding:14px;margin-bottom:16px;">
      <div style="font-size:14px;font-weight:700;margin-bottom:4px;">${d.title}</div>
      <div style="font-size:12px;color:var(--muted);">${d.shop}</div>
      <div style="font-size:24px;font-weight:900;color:var(--orange);margin-top:8px;">£${d.price.toFixed(2)}</div>
    </div>
    <div class="field"><label>Card Number</label><input class="inp-full" placeholder="4242 4242 4242 4242"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      <div class="field"><label>Expiry</label><input class="inp-full" placeholder="MM/YY"></div>
      <div class="field"><label>CVV</label><input class="inp-full" placeholder="123"></div>
    </div>
    <button class="btn-full" onclick="closeModal();showQR(${id});toast('💳 Payment successful!')">Pay £${d.price.toFixed(2)} — Buy Now</button>
    <div style="display:flex;gap:8px;margin-top:10px;">
      <button class="btn-full" style="background:#000;flex:1;" onclick="closeModal();showQR(${id});toast('✅ Apple Pay')">🍎 Pay</button>
      <button class="btn-full" style="background:#fff;color:#000;flex:1;" onclick="closeModal();showQR(${id});toast('✅ Google Pay')">💳 GPay</button>
    </div>
    <p style="font-size:11px;color:var(--muted);text-align:center;margin-top:10px;">🔒 Secured by Stripe</p>
  `);
}

function generateQRSVG(code) {
  const svg = document.getElementById('qr-svg-el');
  const size = 180; const modules = 21; const mod = size/modules;
  // Simple visual QR placeholder
  let d = `<rect width="${size}" height="${size}" fill="white" rx="8"/>`;
  const pattern = [];
  for (let r=0;r<modules;r++){pattern[r]=[];for(let c=0;c<modules;c++){
    const inPos = (r<7&&c<7)||(r<7&&c>=modules-7)||(r>=modules-7&&c<7);
    const border = (r===0||r===6||r===modules-1||r===modules-7)&&inPos;
    const inner = (r>=2&&r<=4&&c>=2&&c<=4)||(r>=2&&r<=4&&c>=modules-5&&c<=modules-3)||(r>=modules-5&&r<=modules-3&&c>=2&&c<=4);
    pattern[r][c] = border||inner||(Math.abs(code.charCodeAt((r*modules+c)%code.length)%3)===0);
  }}
  for(let r=0;r<modules;r++)for(let c=0;c<modules;c++){
    if(pattern[r][c]) d+=`<rect x="${c*mod+1}" y="${r*mod+1}" width="${mod-1}" height="${mod-1}" fill="#111" rx="1"/>`;
  }
  svg.innerHTML = d;
}

// ══════════════════════════════════════════════════════
// SAVED
// ══════════════════════════════════════════════════════
function renderSaved() {
  const el = document.getElementById('saved-content');
  if (!savedDeals.size) {
    el.innerHTML = '<div class="empty-state"><div class="es-icon">⭐</div><div class="es-title">No saved deals yet</div><div class="es-desc">Tap the 🤍 on any deal card to save it here for later.</div></div>';
    return;
  }
  let html = '<div class="sec-lbl">Your Saved Deals</div>';
  DEALS.filter(d=>savedDeals.has(d.id)).forEach(d => {
    html += `<div class="map-row" onclick="openDeal('${d.id}')">
      <div class="map-icon">${d.emoji}</div>
      <div style="flex:1;"><div style="font-size:14px;font-weight:700;">${d.title}</div><div style="font-size:12px;color:var(--muted);">${d.shop}</div></div>
      <div style="text-align:right;"><div style="font-size:12px;color:var(--orange);font-weight:700;">${d.dist}</div><div style="font-size:11px;color:var(--muted);">${d.priceLabel}</div></div>
    </div>`;
  });
  el.innerHTML = html;
}

// ══════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════
function renderAlerts() {
  const el = document.getElementById('alerts-list');
  el.innerHTML = ALERTS_DATA.map(a => `
    <div onclick="openDeal('${a.dealId}')" style="display:flex;gap:11px;padding:13px 16px;border-bottom:1px solid var(--border);cursor:pointer;align-items:flex-start;${a.unread?'background:rgba(255,92,0,.03)':''}">
      <div style="width:42px;height:42px;border-radius:11px;background:${a.bg};display:flex;align-items:center;justify-content:center;font-size:21px;flex-shrink:0;">${a.icon}</div>
      <div style="flex:1;"><div style="font-size:14px;font-weight:700;margin-bottom:2px;">${a.title}</div><div style="font-size:12px;color:var(--muted);">${a.body}</div></div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;"><div style="font-size:11px;color:var(--muted);">${a.time}</div>${a.unread?'<div style="width:8px;height:8px;background:var(--orange);border-radius:50%;"></div>':''}</div>
    </div>`).join('');
}

// ══════════════════════════════════════════════════════
// PROFILE
// ══════════════════════════════════════════════════════
function renderProfile() {
  const el = document.getElementById('profile-content');
  const initials = loggedIn ? userName.slice(0,2).toUpperCase() : 'G';
  const name = loggedIn ? userName : 'Guest';
  el.innerHTML = `
    <div class="profile-header">
      <div class="profile-avatar">${initials}</div>
      <div class="profile-name">${name.charAt(0).toUpperCase()+name.slice(1)}</div>
      <div class="profile-email">${loggedIn?name.toLowerCase()+'@email.com':'Browse mode — no account'}</div>
      ${!loggedIn?`<button class="btn-primary mt12" style="padding:12px;" onclick="showLogin('consumer')">Sign in to buy deals</button>`:''}
    </div>
    <div class="profile-section">
      <div class="ps-title">Purchase History</div>
      ${loggedIn ? `
        <div class="purchase-item" onclick="showQR(0)">
          <div class="pi-icon">☕</div>
          <div class="pi-info"><div class="pi-title">Free Pastry with Coffee</div><div class="pi-meta">The Coffee Spot · Today · FREE</div></div>
          <div class="pi-qr" onclick="event.stopPropagation();showQR(0)">🎟️</div>
        </div>
        <div class="purchase-item" onclick="showQR(1)">
          <div class="pi-icon">✂️</div>
          <div class="pi-info"><div class="pi-title">50% Off Haircut</div><div class="pi-meta">Blades Barbers · Yesterday · £8.00</div></div>
          <div class="pi-qr" onclick="event.stopPropagation();showQR(1)">🎟️</div>
        </div>` :
        '<div style="font-size:13px;color:var(--muted);padding:8px 0;">Sign in to see your purchase history and QR vouchers.</div>'
      }
    </div>
    <div class="profile-section">
      <div class="ps-title">Followed Shops</div>
      ${followedShops.size ? [...followedShops].map(s=>`<div style="font-size:13px;padding:8px 0;border-bottom:1px solid var(--border);">⭐ ${s}</div>`).join(''):'<div style="font-size:13px;color:var(--muted);">No followed shops yet.</div>'}
    </div>`;
}

// ══════════════════════════════════════════════════════
// MAP
// ══════════════════════════════════════════════════════
function renderMapList() {
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => { window._userLat = pos.coords.latitude; window._userLng = pos.coords.longitude; },
      () => {}
    );
  }
  const el = document.getElementById('map-list');
  el.innerHTML = DEALS.slice(0,4).map(d=>`
    <div class="map-row" onclick="openDeal('${d.id}')">
      <div class="map-icon">${d.emoji}</div>
      <div style="flex:1;"><div style="font-size:14px;font-weight:700;">${d.title}</div><div style="font-size:12px;color:var(--muted);">${d.shop}</div></div>
      <div style="text-align:right;"><div style="font-size:12px;color:var(--orange);font-weight:700;">${d.dist}</div><div style="font-size:11px;color:var(--muted);">${fmtSecs(timerSecs[d.id])} left</div></div>
    </div>`).join('');
}

// ══════════════════════════════════════════════════════
// SHOP DASHBOARD
// ══════════════════════════════════════════════════════
function renderShopDash() {
  const stats = [{n:'2',l:'Active Deals'},{n:'178',l:'Views Today'},{n:'23',l:'Walk-ins'}];
  document.getElementById('shop-stats').innerHTML = stats.map(s=>`<div class="stat-card"><div class="stat-n">${s.n}</div><div class="stat-l">${s.l}</div></div>`).join('');
  document.getElementById('recent-deals-list').innerHTML = SHOP_DEALS.slice(0,3).map(d=>{
    const pct = d.total ? (d.remaining/d.total*100).toFixed(0) : 0;
    const badgeClass = d.status==='live'?'badge-live':d.status==='half'?'badge-half':'badge-hot';
    const badgeLabel = d.status==='live'?'● Live':d.status==='half'?'½ Half':d.status==='expired'?'Expired':'Hot!';
    return `<div class="deal-manage-card">
      <div class="dmc-top">
        <div class="dmc-icon">${d.emoji}</div>
        <div class="dmc-info"><div class="dmc-title">${d.title}</div><div class="dmc-meta">${d.type} · ${d.walkins} walk-ins · ${d.views} views</div></div>
        <div class="dmc-badge ${badgeClass}">${badgeLabel}</div>
      </div>
      ${d.status!=='expired'?`<div class="progress-wrap"><div class="progress-bar-bg"><div class="progress-bar-fill" style="width:${pct}%"></div></div><div style="display:flex;justify-content:space-between;margin-top:4px;"><span style="font-size:11px;color:var(--muted);">${d.remaining} remaining of ${d.total}</span><span style="font-size:11px;color:var(--orange);font-weight:700;">${pct}%</span></div></div>`:''}
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════════════════
// SHOP DEALS
// ══════════════════════════════════════════════════════
function renderShopDeals() {
  document.getElementById('shop-deals-list').innerHTML = SHOP_DEALS.map(d=>{
    const pct = d.total ? (d.remaining/d.total*100).toFixed(0) : 0;
    const badgeClass = d.status==='live'?'badge-live':d.status==='half'?'badge-half':'badge-hot';
    const badgeLabel = d.status==='live'?'● Live':d.status==='half'?'½ Half':d.status==='expired'?'Expired':'Hot!';
    return `<div class="deal-manage-card">
      <div class="dmc-top">
        <div class="dmc-icon">${d.emoji}</div>
        <div class="dmc-info"><div class="dmc-title">${d.title}</div><div class="dmc-meta">${d.type} · ${d.views} views · ${d.walkins} walk-ins</div></div>
        <div class="dmc-badge ${badgeClass}">${badgeLabel}</div>
      </div>
      ${d.status!=='expired'?`<div class="progress-wrap"><div class="progress-bar-bg"><div class="progress-bar-fill" style="width:${pct}%"></div></div><div style="display:flex;justify-content:space-between;margin-top:4px;"><span style="font-size:11px;color:var(--muted);">${d.remaining} left of ${d.total}</span><span style="font-size:11px;color:var(--orange);font-weight:700;">${pct}%</span></div></div>`:''}
      <div class="dmc-actions">
        <button class="dmc-act" onclick="toast('✏️ Editing deal...')">✏️ Edit</button>
        <button class="dmc-act" onclick="toast('📊 Deal analytics...')">📊 Stats</button>
        <button class="dmc-act" onclick="toast('🔁 Repeating deal...')">🔁 Repeat</button>
        <button class="dmc-act" style="color:var(--red);" onclick="endDeal('${d.id}')">⛔ End Deal</button>
      </div>
    </div>`;
  }).join('') + '<div style="height:16px;"></div>';
}

// ══════════════════════════════════════════════════════
// CREATE DEAL
// ══════════════════════════════════════════════════════
const stepLabels = ['Deal Info','Deal Type & Timer','Geo & Offers','Post Channels','Preview'];
function renderCreateStep() {
  const el = document.getElementById('create-step-content');
  document.getElementById('create-step-lbl').textContent = `Step ${createStep} of 5 — ${stepLabels[createStep-1]}`;
  document.getElementById('create-step-fill').style.width = (createStep/5*100)+'%';

  if (createStep===1) {
    const imgs = [];
    if (createData.images) {
      // Filter out null entries but keep position
      for (let i = 0; i < 4; i++) {
        const img = createData.images[i];
        if (img && img.length > 50) imgs[i] = img;
        else imgs[i] = null;
      }
    }
    const imgSlots = [0,1,2,3].map(i => {
      const img = imgs[i];
      return img
        ? `<div class="img-slot filled" onclick="removeImage(${i})" title="Tap to remove">
             <img src="${img}" alt="Deal image ${i+1}">
             <div class="img-remove">✕</div>
           </div>`
        : `<div class="img-slot empty" onclick="triggerImageUpload(${i})" title="Add photo">
             <span class="img-plus">+</span>
             <span class="img-hint">Photo</span>
           </div>`;
    }).join('');
    el.innerHTML = `<div class="create-step">
      <div class="field mt12"><label>Deal Photos <span style="color:var(--muted);font-weight:400;">(up to 4)</span></label>
        <div class="img-grid">${imgSlots}</div>
        <input type="file" id="img-file-input" accept="image/*" style="display:none" onchange="handleImageFile(event)">
        <div style="font-size:11px;color:var(--muted);margin-top:6px;">Tap a slot to add a photo from your device</div>
      </div>
      <div class="field mt12"><label>Deal Name</label><input class="inp-full" id="c-name" placeholder="e.g. Free Pastry with Any Coffee" value="${createData.name||''}"></div>
      <div class="field"><label>Description</label><textarea class="inp-full ta" id="c-desc" rows="4" placeholder="Describe your deal...">${createData.desc||''}</textarea>
        <button class="ai-btn mt8" onclick="aiWrite()"><span id="ai-icon">🤖</span> <span id="ai-text">AI Write For Me</span></button>
      </div>
      <div class="field"><label>Price (0 = free)</label><input class="inp-full" id="c-price" type="number" placeholder="0.00" value="${createData.price||''}"></div>
      <button class="btn-full" onclick="createNext()">Next →</button>
    </div>`;
  } else if (createStep===2) {
    el.innerHTML = `<div class="create-step">
      <div style="margin:12px 0 6px;font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;">Deal Type</div>
      <div class="type-grid">
        ${[{k:'Flash Sale',i:'⚡',d:'Short burst, high urgency'},{k:'End of Day',i:'🌅',d:'Clear stock before close'},{k:'Happy Hour',i:'🍻',d:'Fixed time window'},{k:'Ongoing',i:'♻️',d:'Runs until you stop it'}].map(t=>`
        <div class="type-chip ${createData.type===t.k?'sel':''}" onclick="selType(this,'${t.k}')"><div class="tc-icon">${t.i}</div><div class="tc-name">${t.k}</div><div class="tc-desc">${t.d}</div></div>`).join('')}
      </div>
      <div class="field"><label>Start Date/Time</label><input class="inp-full" type="datetime-local" id="c-start"></div>
      <div class="field"><label>End Date/Time</label><input class="inp-full" type="datetime-local" id="c-end"></div>
      <div class="toggle-row"><span style="font-size:14px;flex:1;font-weight:600;">Repeating deal</span><div class="tog ${createData.repeat?'on':''}" onclick="toggleEl(this);createData.repeat=this.classList.contains('on')"></div></div>
      <button class="btn-full" onclick="createNext()">Next →</button>
    </div>`;
  } else if (createStep===3) {
    el.innerHTML = `<div class="create-step">
      <div class="field mt12"><label>Number of Offers (total stock)</label><input class="inp-full" id="c-stock" type="number" placeholder="20" value="${createData.stock||''}"></div>
      <div class="field"><label>Geo-targeting Radius</label>
        <input type="range" min="1" max="10" value="${createData.radius||2}" style="width:100%;margin:8px 0;accent-color:var(--orange);" oninput="document.getElementById('radius-display').textContent=this.value+'mi';createData.radius=this.value">
        <div id="radius-display" style="text-align:center;font-size:14px;font-weight:700;color:var(--orange);">${createData.radius||2}mi</div>
      </div>
      <button class="btn-full" onclick="createNext()">Next →</button>
    </div>`;
  } else if (createStep===4) {
    el.innerHTML = `<div class="create-step">
      <div style="margin:12px 0 14px;font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;">Where to Post</div>
      ${[{k:'oa',i:'📱',l:'Out & About App'},{k:'insta',i:'📸',l:'Instagram (via GHL)'},{k:'fb',i:'👥',l:'Facebook (via GHL)'},{k:'wa',i:'💬',l:'WhatsApp Broadcast'}].map(c=>`
      <div class="toggle-row"><span class="tr-icon">${c.i}</span><span class="tr-label">${c.l}</span><div class="tog ${c.k!=='wa'?'on':''}" onclick="toggleEl(this)"></div></div>`).join('')}
      <button class="btn-full" onclick="createNext()">Next →</button>
    </div>`;
  } else if (createStep===5) {
    // Get first uploaded image for preview background
    var previewImg = "";
    if (createData.images) {
      for (var _pi = 0; _pi < createData.images.length; _pi++) {
        if (createData.images[_pi] && createData.images[_pi].length > 50) {
          previewImg = createData.images[_pi];
          break;
        }
      }
    }
    var previewBg = previewImg ? 'url(' + previewImg + ') center/cover' : 'linear-gradient(135deg,#1a0f00,#2a1f10)';
    var previewContent = previewImg ? '' : '⚡';
    el.innerHTML = `<div class="create-step">
      <div style="font-size:11px;color:var(--orange);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin:12px 0 10px;">Preview</div>
      <div style="background:var(--card);border-radius:16px;overflow:hidden;margin-bottom:16px;">
        <div style="height:100px;background:${previewBg};display:flex;align-items:center;justify-content:center;font-size:42px;">${previewContent}</div>
        <div style="padding:13px;">
          <div style="font-size:15px;font-weight:800;margin-bottom:2px;">${createData.name||'Your Deal Title'}</div>
          <div style="font-size:12px;color:var(--muted);margin-bottom:8px;">Your Shop · 0.2mi away</div>
          <div style="font-size:13px;color:#ccc;line-height:1.7;margin-bottom:10px;">${createData.desc||'Your description...'}</div>
          <div style="display:flex;gap:7px;"><div style="background:rgba(255,92,0,.15);color:var(--orange);border-radius:20px;padding:4px 10px;font-size:11px;font-weight:700;">⚡ ${createData.type||'Flash Sale'}</div><div style="background:var(--card2);color:var(--muted);border-radius:20px;padding:4px 10px;font-size:11px;font-weight:600;">⏱ 5h 47m left</div></div>
        </div>
      </div>
      <button class="btn-full" onclick="publishDeal()">⚡ Smart Post Now</button>
      <button class="btn-ghost" onclick="toast('📋 Saved as draft')">Save as Draft</button>
    </div>`;
  }
}

let _imgSlotTarget = 0;
function triggerImageUpload(slotIndex) {
  _imgSlotTarget = slotIndex;
  const inp = document.getElementById('img-file-input');
  if (inp) { inp.value=''; inp.click(); }
}
function handleImageFile(event) {
  var file = event.target.files[0];
  if (!file) { console.log('[Image] No file selected'); return; }
  console.log('[Image] File selected:', file.name, file.type, Math.round(file.size/1024)+'KB');
  if (file.size > 10 * 1024 * 1024) {
    toast('Image too large — max 10MB');
    console.error('[Image] File too large:', file.size);
    return;
  }
  if (file.type.indexOf('image/') !== 0) {
    toast('Please select an image file');
    return;
  }
  var img = new Image();
  img.onload = function() {
    var w = img.width, h = img.height;
    var maxDim = 800;
    if (w > maxDim || h > maxDim) {
      var scale = Math.min(maxDim/w, maxDim/h);
      w = Math.round(w * scale); h = Math.round(h * scale);
    }
    var canvas = document.createElement('canvas');
    canvas.width = w; canvas.height = h;
    var ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, w, h);
    var resized = canvas.toDataURL('image/jpeg', 0.8);
    if (!createData.images) createData.images = [];
    createData.images[_imgSlotTarget] = resized;
    console.log('[Image] Resized and stored at slot', _imgSlotTarget, resized.length + ' chars');
    console.log('[Image] createData.images now:', JSON.stringify(createData.images.map(function(x){return x ? x.substring(0,40)+'...' : null})));
    renderCreateStep();
  };
  img.onerror = function() {
    toast('Failed to load image');
    console.error('[Image] Failed to load:', file.name);
  };
  img.src = URL.createObjectURL(file);
}
function removeImage(slotIndex) {
  if (createData.images) {
    createData.images[slotIndex] = null;
    renderCreateStep();
  }
}

function createNext() {
  if (createStep===1) { createData.name=document.getElementById('c-name')?.value; createData.desc=document.getElementById('c-desc')?.value; createData.price=document.getElementById('c-price')?.value; }
  if (createStep===2) { createData.type=createData.type||'Flash Sale'; createData.start=document.getElementById('c-start')?.value; createData.end=document.getElementById('c-end')?.value; }
  if (createStep===3) { createData.stock=document.getElementById('c-stock')?.value; }
  if (createStep < 5) { createStep++; renderCreateStep(); }
}

function createBack() {
  if (createStep > 1) { createStep--; renderCreateStep(); }
  else goShop('s-shop-dash');
}

function selType(el, type) {
  document.querySelectorAll('.type-chip').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');
  createData.type = type;
}

let aiLoading = false;
function aiWrite() {
  if (aiLoading) return;
  aiLoading = true;
  document.getElementById('ai-icon').innerHTML = '<span class="ai-spin"></span>';
  document.getElementById('ai-text').textContent = 'Writing...';
  setTimeout(() => {
    document.getElementById('c-desc').value = AI_DESCS[aiIdx % AI_DESCS.length];
    aiIdx++;
    document.getElementById('ai-icon').textContent = '🤖';
    document.getElementById('ai-text').textContent = 'AI Write For Me';
    aiLoading = false;
  }, 1800);
}

function publishDeal() {
  try {
  toast('⚡ Publishing deal...');
  const ts = Date.now();
  // Collect uploaded images (filter out null/empty slots)
  console.log('[Publish] createData.images:', createData.images ? createData.images.map(function(x){return x ? x.substring(0,30) : null}) : 'none');
  var uploadedImages = [];
  if (createData.images) {
    for (var _i = 0; _i < createData.images.length; _i++) {
      if (createData.images[_i] && createData.images[_i].length > 50) {
        uploadedImages.push(createData.images[_i]);
      }
    }
  }
  console.log('[Publish] Collected images count:', uploadedImages.length);
  var dealId = 'deal_' + ts + '_' + Math.random().toString(36).substr(2,6);
  const newDeal = {
    id: dealId, emoji: '⚡', title: createData.name || 'New Deal', shop: userName || 'Your Shop', addr: '', cat: '',
    desc: createData.desc || '', dist: '📍 Live now', price: Number(createData.price)||0,
    priceLabel: createData.price > 0 ? '£'+parseFloat(createData.price).toFixed(2) : 'FREE',
    type: createData.type || 'Flash Sale', status: 'live', views: 0, walkins: 0,
    stock: parseInt(createData.stock) || 10, totalStock: parseInt(createData.stock) || 10,
    timerSecs: 86400, urgency: 'high', lateNight: false, redemptions: 0,
    store_id: userId, end_time: new Date(ts+86400000).toISOString(),
    images: uploadedImages  // Save uploaded photos
  };
  // Insert into main DEALS array so it shows on the consumer feed
  // Insert at beginning so it shows first
  DEALS.unshift(newDeal);
  timerSecs = DEALS.map(d => d.timerSecs || _ts(d.end_time) || 86400);
  // Also keep in SHOP_DEALS for the shop view
  SHOP_DEALS.unshift({...newDeal});
  // Re-render the feed
  renderFeed();
  renderSuccessScreen();
  } catch(e) {
    console.error('publishDeal error:', e);
    toast('❌ Error: ' + e.message);
  }
}

function renderSuccessScreen() {
  // Create a dedicated success screen
  let el = document.getElementById('s-shop-success');
  if (!el) {
    el = document.createElement('div');
    el.id = 's-shop-success';
    el.className = 'screen';
    document.getElementById('app-shell').appendChild(el);
  }
  el.innerHTML = `
    <div class="topbar"><div style="width:28px;"></div><span style="font-size:15px;font-weight:700;">Deal Published</span><div style="width:28px;"></div></div>
    <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:28px;text-align:center;">
      <div style="width:88px;height:88px;background:rgba(46,204,113,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:40px;">✅</div>
      <div style="font-size:26px;font-weight:900;">Deal is Live!</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.7;">Your deal is now visible to everyone near your shop on Out & About.</p>
      <div style="background:var(--card);border-radius:14px;padding:14px;width:100%;text-align:left;">
        <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px;">Auto-generated caption</div>
        <div style="font-size:13px;color:var(--text);line-height:1.7;">⚡ ${createData.name||'Flash deal'} — today only! While stocks last, pop in and treat yourself. #OutAndAbout #LocalDeals</div>
      </div>
      <button class="btn-full" onclick="goShop('s-shop-dash');renderShopDash()">← Back to Dashboard</button>
    </div>`;
  goScreen('s-shop-success');
}

// ══════════════════════════════════════════════════════
// ANALYTICS
