          <div class="field" style="margin-bottom:0;"><label>Geo-targeting radius</label><input class="inp-full" type="range" min="1" max="10" value="2" style="padding:8px 0;background:transparent;border:none;" oninput="document.getElementById('radius-val').textContent=this.value+'mi'"><div id="radius-val" style="font-size:13px;color:var(--orange);font-weight:700;text-align:center;">2mi</div></div>
        </div>
      </div>
      <div class="settings-card">
        <div class="sc-head">Opening Hours</div>
        <div class="sc-field">
          <div style="display:grid;gap:8px;">
            <div class="flex-between"><span style="font-size:13px;">Monday–Friday</span><input class="inp-full" value="7:00 AM – 7:00 PM" style="width:160px;text-align:center;padding:8px;"></div>
            <div class="flex-between"><span style="font-size:13px;">Saturday</span><input class="inp-full" value="8:00 AM – 6:00 PM" style="width:160px;text-align:center;padding:8px;"></div>
            <div class="flex-between"><span style="font-size:13px;">Sunday</span><input class="inp-full" value="Closed" style="width:160px;text-align:center;padding:8px;"></div>
          </div>
          <div class="toggle-row mt12">
            <span class="tr-icon">🌙</span>
            <span class="tr-label" style="font-size:13px;">Show in Night Owl mode</span>
            <div class="tog" onclick="toggleEl(this)"></div>
          </div>
        </div>
      </div>
      <div class="settings-card">
        <div class="sc-head">Notifications</div>
        <div class="sc-field">
          <div class="toggle-row"><span class="tr-icon">👁️</span><span class="tr-label" style="font-size:13px;">Deal view alerts</span><div class="tog on" onclick="toggleEl(this)"></div></div>
          <div class="toggle-row"><span class="tr-icon">⏱️</span><span class="tr-label" style="font-size:13px;">Expiry reminders</span><div class="tog on" onclick="toggleEl(this)"></div></div>
          <div class="toggle-row"><span class="tr-icon">📊</span><span class="tr-label" style="font-size:13px;">Weekly report</span><div class="tog on" onclick="toggleEl(this)"></div></div>
        </div>
      </div>
    </div>
    <div class="sub-card">
      <div class="sub-plan">Starter Plan</div>
      <div class="sub-price">£39.99<span style="font-size:14px;color:var(--muted);font-weight:400;">/mo</span></div>
      <div class="sub-status">Active · Next billing: 13 June 2026</div>
      <button class="btn-primary mt12" style="padding:12px;">Upgrade Plan</button>
    </div>
