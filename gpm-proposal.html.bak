<div class="btm">
<button onclick="n(-1)">← Prev</button>
<span class="pgc" id="pgc">1 / 12</span>
<button class="p" onclick="n(1)">Next →</button>
</div>

<script>
let ci = 0;
const sl = document.querySelectorAll('.sl');
document.getElementById('pb').style.width = (100/sl.length)+'%';
function n(d) {
  sl[ci].classList.remove('on');
  ci = Math.max(0, Math.min(sl.length-1, ci + d));
  sl[ci].classList.add('on');
  document.getElementById('pgc').textContent = (ci+1) + ' / ' + sl.length;
  document.getElementById('pb').style.width = ((ci+1)/sl.length*100)+'%';
}
document.addEventListener('keydown', function(e) {
  if(e.key === 'ArrowRight' || e.key === 'ArrowDown') n(1);
  if(e.key === 'ArrowLeft' || e.key === 'ArrowUp') n(-1);
});
const sa = document.querySelector('.sa') || document.body;
let sx=0,sy=0;
sa.addEventListener('touchstart',e=>{sx=e.changedTouches[0].screenX;sy=e.changedTouches[0].screenY;},{passive:true});
sa.addEventListener('touchend',e=>{const dx=e.changedTouches[0].screenX-sx;const dy=e.changedTouches[0].screenY-sy;if(Math.abs(dx)>Math.abs(dy)&&Math.abs(dx)>30){n(dx<0?1:-1)}},{passive:true});
</script>
</body>
