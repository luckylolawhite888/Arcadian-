<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Langley Renewables — Solar Acquisition Engine</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#091523;
--bg-2:#0e2034;
--bg-3:#0b1a2b;
--ink:#e8dfd1;
--ink-soft:#98a9b9;
--ink-faint:#5c7a9a;
--solar:#f5b342;
--solar-deep:#d48f20;
--line:#1a3050;
--line-bright:#2c405a;
--hot:#22c55e;
--warm:#f5b342;
--cold:#5c6a7a;
--radius:10px;
--font:'Inter','system-ui',-apple-system,sans-serif;
--display:'Inter','system-ui',sans-serif;
}
html{font-size:15px}
body{background:var(--bg);color:var(--ink);font-family:var(--font);min-height:100vh;line-height:1.5}
.app{max-width:1100px;margin:0 auto;padding:20px 24px}
header{padding:4px 0 16px}
.logo{font-size:22px;font-weight:700;letter-spacing:-.3px}
.logo span{color:var(--solar)}
.tagline{font-size:12px;color:var(--ink-soft);margin-top:2px}
.top-bar{display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;margin-bottom:20px;justify-content:space-between}
.bar-left{flex:1;min-width:280px}
.pc-wrap{display:flex;gap:10px}
.pc-wrap input{flex:1;padding:10px 14px;border-radius:var(--radius);border:1px solid var(--line);background:var(--bg-2);color:var(--ink);font-size:15px;font-family:var(--font);outline:0;transition:border-color .15s}
.pc-wrap input:focus{border-color:var(--solar)}
.btn-primary{padding:10px 24px;border-radius:var(--radius);border:none;background:linear-gradient(180deg,var(--solar),var(--solar-deep));color:#0a1400;font-weight:700;font-size:14px;cursor:pointer;font-family:var(--font);display:flex;align-items:center;gap:8px;transition:opacity .15s;white-space:nowrap}
.btn-primary:disabled{opacity:.5;cursor:not-allowed}
.btn-label{position:relative;z-index:1}
.hint{font-size:12px;color:var(--ink-faint);margin-top:6px;min-height:1.2em}
.bar-right{display:flex;gap:24px;align-items:center;flex-shrink:0}
.status{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ink-soft)}
.led{width:8px;height:8px;border-radius:50%;background:var(--cold);display:inline-block}
.led.live{background:var(--hot);animation:pulse 1.2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.prog{font-size:11px;color:var(--ink-faint)}
.counters{display:flex;gap:16px}
.counter{text-align:center}
.counter .k{display:block;font-size:10px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.05em}
.counter .v{font-size:20px;font-weight:700;line-height:1.2}
.counter .v.hot{color:var(--hot)}
.counter .v.warm{color:var(--warm)}
.counter .v.cold{color:var(--cold)}
.radar-wrap{text-align:center;padding:60px 0 30px;position:relative}
.radar{width:160px;height:160px;margin:0 auto;position:relative;border-radius:50%;border:2px solid var(--line-bright);overflow:hidden}
.ring{position:absolute;border-radius:50%;border:1px solid rgba(245,179,66,.12);pointer-events:none}
.r1{width:33%;height:33%;top:33.5%;left:33.5%}
.r2{width:66%;height:66%;top:17%;left:17%}
.r3{width:100%;height:100%;top:0;left:0}
.sweep{position:absolute;width:50%;height:2px;background:linear-gradient(90deg,transparent,var(--solar));top:50%;left:50%;transform-origin:left center;animation:spin 1.5s linear infinite}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:28px;z-index:2}
.scan-msg{font-size:14px;color:var(--ink-soft);margin-top:16px;min-height:1.4em}
.err{margin:16px 0;padding:12px 16px;background:#2d0a14;border:1px solid #5c1828;border-radius:var(--radius);display:flex;gap:10px;align-items:flex-start;font-size:13px}
.err-icon{flex-shrink:0}
.err-msg{color:#f5a0a0}
.empty{text-align:center;padding:80px 20px 60px}
.empty-icon{font-size:44px;margin-bottom:12px}
.empty-title{font-size:18px;font-weight:600;margin-bottom:6px}
.empty-text{font-size:14px;color:var(--ink-soft);max-width:400px;margin:0 auto}
.results.hide{display:none}
.tiles{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:20px}
.tile{background:var(--bg-2);border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px}
.tile .k{font-size:11px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.04em}
.tile .v{font-size:20px;font-weight:700;margin:4px 0;color:#f2e9db}
.tile .u{font-size:11px;color:var(--ink-soft)}
.filters{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.chip{padding:5px 14px;border-radius:20px;border:1px solid var(--line);background:transparent;color:var(--ink-soft);font-size:12px;cursor:pointer;font-family:var(--font);transition:all .15s}
.chip:hover{border-color:var(--ink-soft)}
.chip.active{background:var(--solar);color:#0a1400;border-color:var(--solar);font-weight:600}
.table-wrap{overflow-x:auto;border-radius:var(--radius);border:1px solid var(--line)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{padding:10px 12px;text-align:left;background:var(--bg-3);color:var(--ink-soft);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:.04em;cursor:pointer;white-space:nowrap;user-select:none;border-bottom:1px solid var(--line)}
th .arrow{font-size:9px;color:var(--ink-faint)}
tr{border-bottom:1px solid var(--line);cursor:pointer;transition:background .1s}
tr:last-child{border-bottom:none}
tr:hover{background:var(--bg-2)}
td{padding:10px 12px}
td.idx{color:var(--ink-faint);font-size:12px;width:30px;text-align:center}
.prop-name{font-weight:600;font-size:14px;color:#f2e9db}
.prop-addr{font-size:11px;color:var(--ink-soft);margin-top:1px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.score-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-weight:700;font-size:14px}
.score-badge.hot{background:rgba(34,197,94,.15);color:var(--hot)}
.score-badge.warm{background:rgba(245,179,66,.15);color:var(--warm)}
.score-badge.cold{background:rgba(92,106,122,.2);color:var(--cold)}
.score-icon{font-size:12px}
.prog-bar{height:3px;background:var(--line);border-radius:2px;margin-top:16px;overflow:hidden}
.prog-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--solar),#f7d86a);border-radius:2px;transition:width .3s}
.scrim{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(9,21,35,.7);z-index:98;display:none}
.scrim.show{display:block}
.drawer{position:fixed;top:0;right:0;height:100%;width:min(420px,92vw);background:var(--bg-2);z-index:99;transform:translateX(100%);transition:transform .26s cubic-bezier(.3,.8,.3,1);box-shadow:-20px 0 50px -20px rgba(0,0,0,.5);display:flex;flex-direction:column}
.drawer.open{transform:none}
.drawer header{padding:18px 20px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
.drawer-title{font-weight:700;font-size:16px;flex:1}
.drawer .x{width:30px;height:30px;border-radius:7px;border:1px solid var(--line);background:transparent;color:var(--ink-soft);font-size:16px;cursor:pointer;flex:none;display:flex;align-items:center;justify-content:center}
.drawer-body{padding:16px 20px;overflow-y:auto;flex:1}
.d-row{display:flex;justify-content:space-between;padding:9px 0;font-size:13px;border-bottom:1px solid var(--line)}
.d-row:last-child{border-bottom:none}
.dk{color:var(--ink-soft)}
.dv{font-weight:600;text-align:right;max-width:55%}
.drawer-footer{padding:16px 20px;border-top:1px solid var(--line)}
.copy-btn{width:100%;padding:12px;border-radius:var(--radius);border:none;background:linear-gradient(180deg,var(--solar),var(--solar-deep));color:#0a1400;font-weight:700;font-size:13px;cursor:pointer;font-family:var(--font);transition:opacity .15s}
.copy-btn:active{opacity:.7}
.copy-btn.done{background:var(--line);color:var(--ink-soft)}
@media(max-width:640px){
  .app{padding:14px}
  .top-bar{flex-direction:column}
  .bar-right{width:100%;justify-content:space-between}
  .counters{gap:10px}
  .counter .v{font-size:16px}
  td{font-size:12px;padding:8px}
  .prop-name{font-size:12px}
}
</style>
</head>
<body>
<div class="app" id="app">
  <header>
    <div class="logo">☀️ Langley <span>Solar Engine</span></div>
    <div class="tagline">Commercial solar acquisition intelligence</div>
  </header>
  <div class="top-bar">
    <div class="bar-left">
      <div class="pc-wrap">
        <input type="text" id="pc" placeholder="Enter postcode" value="UB3" autocomplete="off" spellcheck="false">
        <button id="run" class="btn-primary"><span class="btn-label">Run scan</span></button>
      </div>
      <div class="hint" id="hint"></div>
    </div>
    <div class="bar-right">
      <div class="status" id="status">
        <span class="led" id="led"></span>
        <span class="label" id="statusLabel">Ready</span>
      </div>
      <div class="counters">
        <div class="counter"><span class="k">Leads</span><span class="v" id="cLeads">0</span></div>
        <div class="counter"><span class="k">Hot</span><span class="v hot" id="cHot">0</span></div>
        <div class="counter"><span class="k">Warm</span><span class="v warm" id="cWarm">0</span></div>
        <div class="counter"><span class="k">Cold</span><span class="v cold" id="cCold">0</span></div>
      </div>
    </div>
  </div>
  <div class="radar-wrap" id="scanning" hidden>
    <div class="radar">
      <div class="ring r1"></div>
      <div class="ring r2"></div>
      <div class="ring r3"></div>
      <div class="sweep"></div>
      <div class="center">📡</div>
    </div>
    <div class="scan-msg" id="scanMsg">Scanning commercial properties...</div>
  </div>
  <div class="err" id="err" hidden>
    <span class="err-icon">⚠️</span>
    <span class="err-msg" id="errMsg"></span>
  </div>
  <div class="empty" id="empty">
    <div class="empty-icon">🏗️</div>
    <div class="empty-title">No leads yet</div>
    <div class="empty-text">Enter a UK postcode and hit Run scan to discover commercial solar opportunities</div>
  </div>
  <div class="results" id="results" hidden>
    <div class="tiles" id="tiles">
      <div class="tile"><div class="k">Total value</div><div class="v" id="tValue">—</div><div class="u">indicative CAPEX</div></div>
      <div class="tile"><div class="k">Avg saving</div><div class="v" id="tSaving">—</div><div class="u">per year</div></div>
      <div class="tile"><div class="k">Avg CO₂</div><div class="v" id="tCO2">—</div><div class="u">tonnes / year</div></div>
      <div class="tile"><div class="k">Avg payback</div><div class="v" id="tPayback">—</div><div class="u">years</div></div>
    </div>
    <div class="filters" id="filters">
      <button class="chip active" data-filter="all">All</button>
      <button class="chip" data-filter="hot">🔥 Hot</button>
      <button class="chip" data-filter="warm">💛 Warm</button>
      <button class="chip" data-filter="cold">🧊 Cold</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th class="sortable" data-sort="name">Property <span class="arrow">▼</span></th>
            <th class="sortable" data-sort="score">Score <span class="arrow">▼</span></th>
            <th class="sortable" data-sort="kwp">kWp <span class="arrow">▼</span></th>
            <th class="sortable" data-sort="savings">Savings/yr <span class="arrow">▼</span></th>
            <th class="sortable" data-sort="payback">Payback <span class="arrow">▼</span></th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>
  <div class="prog-bar"><div class="prog-fill" id="progFill"></div></div>
</div>
<div class="scrim" id="scrim"></div>
<aside class="drawer" id="drawer" role="dialog" aria-label="Lead detail">
  <header>
    <div class="drawer-title" id="dTitle"></div>
    <button class="x" id="dClose" aria-label="Close drawer">✕</button>
  </header>
  <div class="drawer-body" id="dBody"></div>
  <div class="drawer-footer">
    <button class="copy-btn" id="dCopy">📋 Copy lead summary</button>
  </div>
</aside>
<script>
(function(){
var $=function(id){return document.getElementById(id);};
var pc=$('pc'),run=$('run'),hint=$('hint'),led=$('led');
var statusLabel=$('statusLabel'),scanning=$('scanning'),scanMsg=$('scanMsg');
var err=$('err'),errMsg=$('errMsg'),empty=$('empty');
var results=$('results'),tiles=$('tiles'),tbody=$('tbody');
var tValue=$('tValue'),tSaving=$('tSaving'),tCO2=$('tCO2'),tPayback=$('tPayback');
var cLeads=$('cLeads'),cHot=$('cHot'),cWarm=$('cWarm'),cCold=$('cCold');
var filters=$('filters'),scrim=$('scrim'),drawer=$('drawer');
var dTitle=$('dTitle'),dBody=$('dBody'),progFill=$('progFill');
var leads=[],current=null,state={filter:'all',sort:'score',asc:false};
var gbp=new Intl.NumberFormat('en-GB',{style:'currency',currency:'GBP',maximumFractionDigits:0});
var n0=new Intl.NumberFormat('en-GB',{maximumFractionDigits:0});
var n1=new Intl.NumberFormat('en-GB',{maximumFractionDigits:1});
var tickTimer;

function showErr(m){errMsg.textContent=m;err.hidden=false;setTimeout(function(){err.hidden=true;},8000);}
function avg(k,l){var s=0,c=0;l.forEach(function(v){if(v[k]){s+=v[k];c++;}});return c?s/c:0;}
function esc(s){return(s||'').replace(/[&<>]/g,function(m){if(m==='&')return'&amp;';if(m==='<')return'&lt;';return'&gt;';});}

function runScan(){
  var pcv=pc.value.trim().toUpperCase();
  if(!pcv)return showErr('Please enter a postcode');
  run.disabled=true;run.querySelector('.btn-label').textContent='Scanning';
  scanning.hidden=false;empty.hidden=true;results.hidden=true;err.hidden=true;
  led.className='led live';statusLabel.textContent='Scanning...';
  progFill.style.width='5%';
  var startTime=Date.now(),dots=0;
  tickTimer=setInterval(function(){
    dots=(dots+1)%4;scanMsg.textContent='Scanning commercial properties'+'.'.repeat(dots);
    var pct=Math.min(95,5+(Date.now()-startTime)/400);
    progFill.style.width=pct+'%';
  },500);
  var url='/api/scan?postcode='+encodeURIComponent(pcv);
  fetch(url).then(function(r){return r.json();}).then(function(data){
    clearInterval(tickTimer);
    leads=(data.leads||[]).sort(function(a,b){return b.score-a.score;});
    scanning.hidden=true;results.hidden=false;
    led.className='led';statusLabel.textContent='Ready ('+leads.length+' leads)';
    progFill.style.width='100%';setTimeout(function(){progFill.style.width='0%';},600);
    run.disabled=false;run.querySelector('.btn-label').textContent='Run scan';
    render();
  }).catch(function(e){
    clearInterval(tickTimer);scanning.hidden=true;empty.hidden=false;results.hidden=true;
    led.className='led';statusLabel.textContent='Error';
    progFill.style.width='0%';run.disabled=false;run.querySelector('.btn-label').textContent='Run scan';
    showErr(e.message||'Scan failed');
  });
}

function render(){
  var filtered=leads.filter(function(l){
    if(state.filter==='all')return true;
    var t=l.score>=72?'hot':l.score>=53?'warm':'cold';
    return t===state.filter;
  });
  var key=state.sort,dir=state.asc?1:-1;
  filtered.sort(function(a,b){
    var av=a[key],bv=b[key];
    if(typeof av==='string')av=av.toLowerCase();
    if(typeof bv==='string')bv=bv.toLowerCase();
    if(av<bv)return -dir;if(av>bv)return dir;return 0;
  });
  var hot=0,warm=0,cold=0;
  leads.forEach(function(l){
    var t=l.score>=72?'hot':l.score>=53?'warm':'cold';
    if(t==='hot')hot++;else if(t==='warm')warm++;else cold++;
  });
  cLeads.textContent=leads.length;
  cHot.textContent=hot;cWarm.textContent=warm;cCold.textContent=cold;
  tValue.textContent=gbp.format(avg('capex',filtered));
  tSaving.textContent=gbp.format(avg('savings',filtered));
  tCO2.textContent=n1.format(avg('co2',filtered));
  tPayback.textContent=n1.format(avg('payback',filtered));
  var html='';
  filtered.forEach(function(l,i){
    var sc=l.score,cl=sc>=72?'hot':sc>=53?'warm':'cold';
    var ts=sc>=72?'🔥':sc>=53?'💛':'🧊';
    html+='<tr class="lead-row" data-idx="'+i+'" onclick="openDrawer('+i+')">'
      +'<td class="idx">'+(i+1)+'</td>'
      +'<td><div class="prop-name">'+esc(l.name)+'</div><div class="prop-addr">'+esc(l.addr)+'</div></td>'
      +'<td><span class="score-badge '+cl+'">'+sc+'<span class="score-icon">'+ts+'</span></span></td>'
      +'<td>'+l.kwp+'</td>'
      +'<td>'+gbp.format(l.savings||0)+'</td>'
      +'<td>'+n1.format(l.payback||0)+'</td>'
      +'</tr>';
  });
  tbody.innerHTML=html;
}

window.openDrawer=function(idx){
  current=leads.filter(function(l){
    if(state.filter==='all')return true;
    var t=l.score>=72?'hot':l.score>=53?'warm':'cold';
    return t===state.filter;
  })[idx];
  if(!current)return;
  var l=current;
  dTitle.textContent=l.name;
  dBody.innerHTML=''
    +'<div class="d-row"><span class="dk">Address</span><span class="dv">'+esc(l.addr)+'</span></div>'
    +'<div class="d-row"><span class="dk">Type</span><span class="dv">'+esc(l.type||'-')+'</span></div>'
    +'<div class="d-row"><span class="dk">Score</span><span class="dv">'+l.score+'/100 ('+l.temp+')</span></div>'
    +'<div class="d-row"><span class="dk">System size</span><span class="dv">'+l.kwp+' kWp</span></div>'
    +'<div class="d-row"><span class="dk">Annual savings</span><span class="dv">'+gbp.format(l.savings||0)+'</span></div>'
    +'<div class="d-row"><span class="dk">Payback period</span><span class="dv">'+n1.format(l.payback||0)+' yr</span></div>'
    +'<div class="d-row"><span class="dk">Indicative cost</span><span class="dv">'+gbp.format(l.capex||0)+'</span></div>'
    +'<div class="d-row"><span class="dk">CO2 avoided</span><span class="dv">'+n1.format(l.co2||0)+' t/yr</span></div>'
    +'<div class="d-row"><span class="dk">Company no.</span><span class="dv">'+(l.company_number||'-')+'</span></div>';
  drawer.classList.add('open');scrim.classList.add('show');
};
function closeD(){drawer.classList.remove('open');scrim.classList.remove('show');}
$('dClose').addEventListener('click',closeD);
scrim.addEventListener('click',closeD);
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeD();});
$('dCopy').addEventListener('click',function(){
  if(!current)return;var l=current;
  var t=l.name+' - '+l.type+'\n'+l.addr+'\nScore: '+l.score+'/100 ('+l.temp+')\nSystem: '+l.kwp+' kWp | Savings: '+gbp.format(l.savings||0)+'/yr | Payback: '+n1.format(l.payback||0)+' yr\nCO2 avoided: '+n1.format(l.co2||0)+' t/yr | Indicative cost: '+gbp.format(l.capex||0);
  var b=this;
  function d(){b.textContent='Copied OK';b.classList.add('done');}
  try{navigator.clipboard.writeText(t).then(d,d);}catch(e){d();}
});
run.addEventListener('click',runScan);
pc.addEventListener('keydown',function(e){if(e.key==='Enter')runScan();});
filters.addEventListener('click',function(e){
  var b=e.target.closest('.chip');if(!b)return;
  state.filter=b.getAttribute('data-filter');
  Array.from(filters.children).forEach(function(c){c.classList.toggle('active',c===b);});
  render();
});
Array.from(document.querySelectorAll('th.sortable')).forEach(function(th){
  th.addEventListener('click',function(){
    var key=th.getAttribute('data-sort');
    if(state.sort===key)state.asc=!state.asc;
    else{state.sort=key;state.asc=false;}
    th.querySelector('.arrow').textContent=state.asc?'▲':'▼';
    render();
  });
});
setTimeout(runScan,800);
})();
</script>
</body>
</html>
