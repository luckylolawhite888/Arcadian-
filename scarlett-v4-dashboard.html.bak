              <svg viewBox="0 0 24 24"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/></svg>
            </button>
          </div>
        </div>

        <div class="chat-side">
          <div class="card" style="margin-bottom:16px">
            <div class="card-head"><div class="card-title">Today with Scarlett</div></div>
            <div class="side-stat"><span>Actions completed</span><b>14</b></div>
            <div class="side-stat"><span>Emails drafted</span><b>9</b></div>
            <div class="side-stat"><span>Leads enriched</span><b>6</b></div>
            <div class="side-stat"><span>Awaiting your approval</span><b style="color:var(--orange-deep)">3</b></div>
          </div>
          <div class="card">
            <div class="card-head"><div class="card-title">Scarlett can…</div></div>
            <div class="cap-list">
              <div class="cap"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>Find and qualify new leads</div>
              <div class="cap"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>Draft and schedule outreach</div>
              <div class="cap"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>Enrich companies via Apollo</div>
              <div class="cap"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>Summarise replies and threads</div>
              <div class="cap"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>Book meetings into your calendar</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 10. VOICE ============ -->
    <section id="page-voice" class="page">
      <div class="voice-wrap">
        <div class="card voice-card">
          <h3>Scarlett's Voice</h3>
          <span class="eyebrow">Text to speech · ElevenLabs-ready</span>
          <div class="field">
            <label for="voiceSelect">Voice</label>
            <select id="voiceSelect">
              <option value="scarlett">Scarlett — British, warm (default)</option>
            </select>
          </div>
          <div class="field">
            <label for="voiceText">Text to speak</label>
            <textarea id="voiceText" rows="5">Good morning, Darren. You have three approvals waiting and Sofia Martín's call at half past ten. Referrals are still your strongest channel this week.</textarea>
          </div>
          <div class="voice-actions">
            <button class="primary-btn" id="voicePlayBtn" onclick="playVoice()">
              <svg viewBox="0 0 24 24"><path d="M6 4l14 8-14 8z" fill="#fff" stroke="none"/></svg>
              Play
            </button>
            <button class="ghost-btn" onclick="stopVoice()">Stop</button>
            <div class="wave" id="voiceWave"><i></i><i></i><i></i><i></i><i></i></div>
            <span id="voiceStatus">READY</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 11. SETTINGS ============ -->
    <section id="page-settings" class="page">
      <div class="set-grid">
        <div class="card set-section">
          <h3>Access code</h3>
          <span class="eyebrow">Change the Mission Control lock code</span>
          <div class="field">
            <label for="currentCode">Current code</label>
            <input type="password" id="currentCode" autocomplete="off">
          </div>
          <div class="field">
            <label for="newCode">New code</label>
            <input type="password" id="newCode" autocomplete="off">
          </div>
          <div class="field">
            <label for="confirmCode">Confirm new code</label>
            <input type="password" id="confirmCode" autocomplete="off">
          </div>
          <button class="dark-btn" id="updateCodeBtn" onclick="updateCode()">Update code</button>
        </div>

        <div class="card set-section">
          <h3>API status</h3>
          <span class="eyebrow">Live health of connected services</span>
          <div id="apiStatus">
            <div class="status-row" data-service="core"><span class="s-dot unknown"></span><div class="s-name">Core API<span class="s-sub">/api — stats, leads, tasks</span></div><span class="mono">CHECKING…</span></div>
            <div class="status-row" data-service="scarlett"><span class="s-dot unknown"></span><div class="s-name">Scarlett Engine<span class="s-sub">Chat, lead finding, briefings</span></div><span class="mono">CHECKING…</span></div>
            <div class="status-row" data-service="companies-house"><span class="s-dot unknown"></span><div class="s-name">Companies House<span class="s-sub">UK company search</span></div><span class="mono">CHECKING…</span></div>
            <div class="status-row" data-service="apollo"><span class="s-dot unknown"></span><div class="s-name">Apollo<span class="s-sub">Contact enrichment</span></div><span class="mono">CHECKING…</span></div>
            <div class="status-row" data-service="weather"><span class="s-dot unknown"></span><div class="s-name">Weather<span class="s-sub">Topbar + briefing feed</span></div><span class="mono">CHECKING…</span></div>
            <div class="status-row" data-service="voice"><span class="s-dot unknown"></span><div class="s-name">Voice / TTS<span class="s-sub">ElevenLabs</span></div><span class="mono">CHECKING…</span></div>
          </div>
        </div>
      </div>
    </section>

  </div>
</div>

<!-- ================= LEAD DRAWER ================= -->
<div id="leadDrawer" class="drawer-overlay" onclick="if(event.target===this)closeLeadDrawer()">
  <div class="drawer-panel">
    <button class="drawer-close" onclick="closeLeadDrawer()" aria-label="Close">✕</button>
    <div class="drawer-header">
      <span class="eyebrow">Lead Details</span>
      <div class="drawer-name" id="drawerName">—</div>
      <div class="drawer-company" id="drawerCompany">—</div>
    </div>
    <div class="drawer-body">
      <div class="drawer-grid">
        <div class="dg-item"><span class="dg-label">Status</span><span class="dg-value" id="drawStatus">—</span></div>
        <div class="dg-item"><span class="dg-label">Priority</span><span class="dg-value" id="drawPriority">—</span></div>
        <div class="dg-item"><span class="dg-label">Source</span><span class="dg-value" id="drawSource">—</span></div>
        <div class="dg-item"><span class="dg-label">Value</span><span class="dg-value" id="drawValue">—</span></div>
        <div class="dg-item"><span class="dg-label">Location</span><span class="dg-value" id="drawLocation">—</span></div>
        <div class="dg-item"><span class="dg-label">Last Activity</span><span class="dg-value" id="drawActivity">—</span></div>
        <div class="dg-item"><span class="dg-label">Email</span><span class="dg-value" id="drawEmail">—</span></div>
        <div class="dg-item"><span class="dg-label">Phone</span><span class="dg-value" id="drawPhone">—</span></div>
        <div class="dg-item"><span class="dg-label">Website</span><span class="dg-value" id="drawWebsite">—</span></div>
        <div class="dg-item full"><span class="dg-label">Contact</span><span class="dg-value" id="drawContact">—</span></div>      </div>
      <div class="drawer-actions" id="drawerActions">
        <button class="btn btn-outline" onclick="doEnrichLead()" id="drawerEnrichBtn">🔍 Enrich</button>
        <button class="btn btn-outline" onclick="doApproveLead()" id="drawerApproveBtn" style="border-color:var(--green);color:var(--green)">✅ Approve</button>
        <button class="btn btn-outline" onclick="doRejectLead()" id="drawerRejectBtn" style="border-color:var(--red);color:var(--red)">❌ Reject</button>
      </div>
    </div>
  </div>
</div>

<!-- ================= WEATHER OVERLAY ================= -->
<div id="weatherOverlay" role="dialog" aria-modal="true" aria-label="Weather">
  <button class="weather-close" onclick="toggleWeatherApp()" aria-label="Close weather">✕</button>
  <div class="weather-panel">
    <span class="eyebrow">Current Conditions</span>
    <div id="wCity">Madrid</div>
    <div id="wIcon">☀️</div>
    <div id="wTemp">21°</div>
    <div id="wCondition">Sunny with clear skies</div>
    <div id="wFeels">Feels like 23°</div>
    <div class="weather-stats">
      <div class="w-stat"><span class="mono">Humidity</span><b id="wHumidity">38%</b></div>
      <div class="w-stat"><span class="mono">Wind</span><b id="wWind">12</b><span>km/h</span></div>
      <div class="w-stat"><span class="mono">UV Index</span><b id="wUV">7</b><span>High</span></div>
    </div>
  </div>
</div>

<div class="toast" id="toast"><i></i><span id="toastMsg"></span></div>

<script>
/* ================================================================
   GPM MISSION CONTROL — FRONT END
   All backend hooks are in the API LAYER section below.
   Every loader tries your endpoint first and falls back to the
   demo data already rendered in the HTML, so the UI never breaks
   while you wire things up.
   ================================================================ */

/* ================= API LAYER =================
   Change endpoints here. */
const API = {
  auth:        '/api/auth',
  stats:       '/api/stats',
  leads:       '/api/leads',
  tasks:       '/api/tasks',
  campaigns:   '/api/campaigns',
  weather:     '/api/weather',
  briefing:    '/api/briefing',
  calendar:    '/api/calendar',
  approvals:   '/api/approvals',
  chat:        '/api/chat',
  voice:       '/api/voice',
  voices:      '/api/voice/voices',
  code:        '/api/code',
  status:      '/api/status',
  searchCompany:'/api/search-company',
  enrich:      '/api/enrich'
};
const ACCESS_CODE = '@DARREN2026';

async function apiGet(url){
  try{ 
    const r = await fetch(url, { headers: {'x-access-code': ACCESS_CODE} }); 
    if(!r.ok) throw r.status; 
    return await r.json(); 
  }
  catch(e){ return null; }
}
async function apiPost(url, body, skipAuth){
  try{
    const headers = {'Content-Type':'application/json'};
    if(!skipAuth) headers['x-access-code'] = ACCESS_CODE;
    const r = await fetch(url,{ method:'POST', headers, body:JSON.stringify(body) });
    if(!r.ok) throw r.status; 
    return await r.json();
  }catch(e){ return null; }
}

/* ================= LOGIN ================= */
async function attemptLogin(){
  const code = document.getElementById('loginCode').value.trim();
  if(!code) return loginFail();
  // Try API auth first (without auth header since this IS the auth call)
  const res = await apiPost(API.auth, {'x-access-code': code}, true);
  // If API succeeds use its validation, else accept any code (auth will be fixed later)
  if(res && res.valid){ unlock(); }
  else if(res && res.error){ loginFail(); }
  } else if(code === ACCESS_CODE){ unlock(); }
  else{ loginFail(); }
}
}
function loginFail(){
  const ov = document.getElementById('loginOverlay');
  document.getElementById('loginError').classList.add('show');
  ov.classList.remove('shake'); void ov.offsetWidth; ov.classList.add('shake');
  const inp = document.getElementById('loginCode');
  inp.value = ''; inp.focus();
}
function unlock(){
  document.getElementById('loginOverlay').classList.add('hidden');
  document.getElementById('loginError').classList.remove('show');
  bootData();
}
function lockApp(){
  document.getElementById('loginOverlay').classList.remove('hidden');
  document.getElementById('loginCode').value = '';
  setTimeout(()=>document.getElementById('loginCode').focus(), 350);
}
document.getElementById('loginCode').focus();

/* ================= NAVIGATION ================= */
const TITLES = {
  'dashboard':  ['OPS / 01','Dashboard'],
  'leads':      ['OPS / 02','Leads'],
  'tasks':      ['OPS / 03','Tasks'],
  'campaigns':  ['OPS / 04','Campaigns'],
  'sales-intel':['OPS / 05','Sales Intel'],
  'briefing':   ['INTEL / 01','Daily Briefing'],
  'calendar':   ['INTEL / 02','Calendar'],
  'approvals':  ['INTEL / 03','Approvals'],
  'chat':       ['SCARLETT / 01','Chat'],
  'voice':      ['SCARLETT / 02','Voice'],
  'settings':   ['SYS / 01','Settings']
};
function nav(id, el){
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  (el || document.querySelector('[data-page="'+id+'"]')).classList.add('active');
  const t = TITLES[id];
  document.getElementById('crumb').textContent = t[0];
  document.getElementById('pageTitle').textContent = t[1];
  document.getElementById('content').scrollTop = 0;
  toggleSidebar(false);
}
function toggleSidebar(open){
  document.getElementById('sidebar').classList.toggle('open', open);
  document.getElementById('overlayDim').classList.toggle('show', open);
}
function setTab(el){
  el.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

/* ================= CLOCK & GREETING ================= */
function pad(n){ return String(n).padStart(2,'0'); }
function updateClock(){
  const now = new Date();
  document.getElementById('clock').innerHTML =
    pad(now.getHours()) + ':' + pad(now.getMinutes()) + '<span class="sec">:' + pad(now.getSeconds()) + '</span>';
  document.getElementById('clockDate').textContent =
    now.toLocaleDateString('en-GB',{weekday:'short',day:'2-digit',month:'short'}).toUpperCase();
}
setInterval(updateClock, 1000);
updateClock();
(function(){
  const h = new Date().getHours();
  document.getElementById('greet').textContent =
    (h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening');
  document.getElementById('briefingDate').textContent =
    new Date().toLocaleDateString('en-GB',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});
})();

/* ================= DATA BOOT (called after login) ================= */
function bootData(){
  loadStats(); loadLeads(); loadTasks(); loadCampaigns();
  loadWeather(); loadBriefing(); loadCalendar(); loadApprovals();
  loadVoices(); loadApiStatus();
}

/* ---- Stats → #statLeads #statEmails #statReplies #statTasks ---- */
async function loadStats(){
  const d = await apiGet(API.stats);
  if(!d) return; // keep demo values
  if(d.leads   != null) document.getElementById('statLeads').textContent   = d.leads;
  if(d.emails  != null) document.getElementById('statEmails').textContent  = d.emails;
  if(d.replies != null) document.getElementById('statReplies').textContent = d.replies;
  if(d.tasks   != null) document.getElementById('statTasks').textContent   = d.tasks;
  if(d.leads   != null) document.getElementById('navLeadsCount').textContent = d.leads;
  if(d.tasks   != null) document.getElementById('navTasksCount').textContent = d.tasks;
}

/* ---- Leads → #leadsTableBody ----
   Expected: [{name, company, source, status, priority, value, lastActivity}] */
const PILL = {new:'new',contacted:'contacted',qualified:'qualified','follow-up':'followup',followup:'followup',cold:'cold',won:'won'};
async function loadLeads(){
  const d = await apiGet(API.leads);
  if(!d || !Array.isArray(d) || !d.length) return;
  ALL_LEADS = d;
  document.getElementById('leadsTableBody').innerHTML = d.map(l => {
    const s = (l.status||'new').toLowerCase();
    return `<tr data-s="${PILL[s]||'new'}" onclick="viewLead('${esc(l.id||'')}')" style="cursor:pointer">
      <td><div class="cell-name">${esc(l.contact_name||l.name||"???")}</div><div class="cell-sub">${esc(l.company_name||l.company||'')}</div></td>
      <td class="mono">${esc(l.source||'—')}</td>
      <td><span class="pill ${PILL[s]||'new'}">${esc(l.status||'New')}</span></td>
      <td><span class="prio ${(l.priority||'low').toLowerCase()==='high'?'high':(l.priority||'').toLowerCase()==='med'?'med':'low'}">${esc((l.priority||'LOW').toUpperCase())}</span></td>
      <td class="mono">${esc(l.value||'—')}</td>
      <td class="mono">${esc(l.lastActivity||l.updated_at||l.created_at||'—')}</td></tr>`;
  }).join('');
}
function filterLeads(key, el){
  setTab(el);
  document.querySelectorAll('#leadsTableBody tr').forEach(r => {
    r.style.display = (key === 'all' || r.dataset.s === key) ? '' : 'none';
  });
}
async function findLeads(){
  const btn = document.getElementById('findLeadsBtn');
  btn.disabled = true; btn.style.opacity = .6;
  toast("Scarlett's lead engine started…");
  // Wire this: e.g. POST /api/leads/find, then reload the table
  setTimeout(() => { btn.disabled = false; btn.style.opacity = 1; toast('Lead search — wire to backend'); }, 1400);
}

/* ---- Tasks → #tasksTableBody ----
   Expected: [{title, detail, status, priority, due, assigned}] */
const TPILL = {'to do':'todo',todo:'todo','in progress':'progress-p',waiting:'blocked',blocked:'blocked',done:'done'};
async function loadTasks(){
  const d = await apiGet(API.tasks);
  if(!d || !Array.isArray(d) || !d.length) return;
  document.getElementById('tasksTableBody').innerHTML = d.map(t => {
    const s = (t.status||'to do').toLowerCase();
    return `<tr>
      <td><div class="cell-name">${esc(t.title)}</div><div class="cell-sub">${esc(t.detail||'')}</div></td>
      <td><span class="pill ${TPILL[s]||'todo'}">${esc(t.status||'To do')}</span></td>
      <td><span class="prio ${(t.priority||'').toLowerCase()==='high'?'high':(t.priority||'').toLowerCase()==='med'?'med':'low'}">${esc((t.priority||'LOW').toUpperCase())}</span></td>
      <td class="mono">${esc(t.due||'—')}</td>
      <td>${esc(t.assigned||'—')}</td></tr>`;
  }).join('');
}

/* ---- Campaigns → #campaignsTableBody ----
   Expected: [{name, detail, status, sent, openRate, replyRate, nextSend}] */
const CPILL = {live:'live',scheduled:'sched',draft:'draft',complete:'won'};
async function loadCampaigns(){
  const d = await apiGet(API.campaigns);
  if(!d || !Array.isArray(d) || !d.length) return;
  document.getElementById('campaignsTableBody').innerHTML = d.map(c => {
    const s = (c.status||'draft').toLowerCase();
    return `<tr>
      <td><div class="cell-name">${esc(c.name)}</div><div class="cell-sub">${esc(c.detail||'')}</div></td>
      <td><span class="pill ${CPILL[s]||'draft'}">${esc(c.status||'Draft')}</span></td>
      <td class="mono">${esc(c.sent??'—')}</td>
      <td class="mono">${esc(c.openRate??'—')}</td>
      <td class="mono">${esc(c.replyRate??'—')}</td>
      <td class="mono">${esc(c.nextSend||'—')}</td></tr>`;
  }).join('');
}

/* ---- Weather → topbar + overlay + briefing strip ----
   Expected: {city, temp, feelsLike, condition, humidity, wind, uv, icon, high, low} */
const W_ICONS = {sun:'☀️',clear:'☀️',cloud:'⛅',overcast:'☁️',rain:'🌧️',storm:'⛈️',snow:'❄️',fog:'🌫️',night:'🌙'};
function weatherIcon(cond){
  const c = (cond||'').toLowerCase();
  for(const k in W_ICONS){ if(c.includes(k)) return W_ICONS[k]; }
  return '☀️';
}
async function loadWeather(){
  const d = await apiGet(API.weather);
  if(!d) return; // demo values stay
  const icon = d.icon || weatherIcon(d.condition);
  setText('topbarWeatherTemp', Math.round(d.temp) + '°');
  setText('topbarWeatherCity', d.city || 'Madrid');
  document.getElementById('topbarWeatherIcon').textContent = icon;
  setText('wCity', d.city || 'Madrid');
  document.getElementById('wIcon').textContent = icon;
  setText('wTemp', Math.round(d.temp) + '°');
  setText('wCondition', d.condition || '—');
  setText('wFeels', 'Feels like ' + Math.round(d.feelsLike ?? d.temp) + '°');
  setText('wHumidity', (d.humidity ?? '—') + '%');
  setText('wWind', d.wind ?? '—');
  setText('wUV', d.uv ?? '—');
  setText('bwCondition', d.condition || '—');
  setText('bwTemp', Math.round(d.temp) + '°C');
  if(d.high != null) setText('bwHiLo', Math.round(d.high) + '° / ' + Math.round(d.low) + '°');
  setText('bwWind', (d.wind ?? '—') + ' km/h');
}
function toggleWeatherApp(){
  document.getElementById('weatherOverlay').classList.toggle('open');
}
document.addEventListener('keydown', e => {
  if(e.key === 'Escape') document.getElementById('weatherOverlay').classList.remove('open');
});

/* ---- Briefing → #briefingContent + #headlinesList ----
   Expected: {content: [paragraphs] or html, headlines: [{source, title, meta}]} */
async function loadBriefing(){
  const d = await apiGet(API.briefing);
  if(!d) return;
  if(Array.isArray(d.content)){
    document.getElementById('briefingContent').innerHTML = d.content.map(p => '<p>' + esc(p) + '</p>').join('');
  } else if(typeof d.content === 'string'){
    document.getElementById('briefingContent').innerHTML = '<p>' + esc(d.content) + '</p>';
  }
  if(Array.isArray(d.headlines) && d.headlines.length){
    document.getElementById('headlinesList').innerHTML = d.headlines.map(h =>
      `<div class="headline"><span class="h-src">${esc(h.source||'News')}</span><div><p>${esc(h.title)}</p><span>${esc(h.meta||'')}</span></div></div>`
    ).join('');
  }
}
function speakBriefing(){
  const text = document.getElementById('briefingContent').innerText;
  document.getElementById('voiceText').value = text;
  nav('voice', document.querySelector('[data-page="voice"]'));
  playVoice();
}

/* ---- Calendar → #calendarList ----
   Expected: [{group:'Today', label:'Thu 02 Jul', events:[{time, title, detail, color}]}] */
async function loadCalendar(){
  const d = await apiGet(API.calendar);
  if(!d || !Array.isArray(d) || !d.length) return;
  const COLORS = {orange:'var(--orange)', green:'var(--green)', black:'var(--ink)', blue:'var(--blue)'};
  document.getElementById('calendarList').innerHTML = d.map(g => `
    <div class="card cal-day" style="margin-bottom:14px">
      <div class="cal-day-head"><b>${esc(g.group)}</b><span class="eyebrow">${esc(g.label||'')}</span></div>
      ${(g.events||[]).map(ev => `
        <div class="cal-evt">
          <span class="time">${esc(ev.time||'')}</span>
          <span class="bar" style="background:${COLORS[ev.color]||'var(--orange)'}"></span>
          <div><div class="cell-name">${esc(ev.title)}</div><div class="cell-sub">${esc(ev.detail||'')}</div></div>
        </div>`).join('')}
    </div>`).join('');
}

/* ---- Approvals → #approvalsList ----
   Expected: [{id, initials, name, role, company, domain, value, reason}] */
async function loadApprovals(){
  const d = await apiGet(API.approvals);
  if(!d || !Array.isArray(d)) return;
  document.getElementById('navApprovalsCount').textContent = d.length;
  if(!d.length){
    document.getElementById('approvalsList').innerHTML =
      '<div class="card" style="padding:32px;text-align:center;color:var(--faint);font-size:13px">All caught up — no approvals pending.</div>';
    return;
  }
  document.getElementById('approvalsList').innerHTML = d.map(a => `
    <div class="card approval" data-id="${esc(a.id??'')}">
      <div class="lead-avatar">${esc(a.initials || (a.name||'?').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase())}</div>
      <div class="ap-body">
        <div class="cell-name">${esc(a.name)}${a.role ? ' — ' + esc(a.role) : ''}</div>
        <div class="cell-sub">${esc(a.company||'')}${a.domain ? ' · ' + esc(a.domain) : ''}${a.value ? ' · Est. value ' + esc(a.value) : ''}</div>
        ${a.reason ? '<div class="ap-reason">Scarlett: "' + esc(a.reason) + '"</div>' : ''}
      </div>
      <div class="ap-actions">
        <button class="approve-btn" onclick="approveLead(this,'${esc(a.name)}')">Approve</button>
        <button class="reject-btn" onclick="rejectLead(this,'${esc(a.name)}')">Reject</button>
      </div>
    </div>`).join('');
}
function resolveApproval(btn){
  const card = btn.closest('.approval');
  card.style.transition = 'opacity .25s, transform .25s';
  card.style.opacity = 0; card.style.transform = 'translateX(16px)';
  setTimeout(() => {
    card.remove();
    const left = document.querySelectorAll('#approvalsList .approval').length;
    document.getElementById('navApprovalsCount').textContent = left;
    if(!left) document.getElementById('approvalsList').innerHTML =
      '<div class="card" style="padding:32px;text-align:center;color:var(--faint);font-size:13px">All caught up — no approvals pending.</div>';
  }, 260);
}
function approveLead(btn, name){
  // Wire this: POST approval decision with card's data-id
  resolveApproval(btn);
  toast(name + ' approved → added to lead queue');
}
function rejectLead(btn, name){
  resolveApproval(btn);
  toast(name + ' rejected');
}

/* ---- Chat ---- */
function timeNow(){ const n = new Date(); return pad(n.getHours()) + ':' + pad(n.getMinutes()); }
function addMsg(text, who){
  const box = document.getElementById('chatBox');
  const typing = document.getElementById('chatTyping');
  const m = document.createElement('div');
  m.className = 'msg ' + who;
  m.innerHTML = '<div class="bubble"></div><div class="msg-time">' + timeNow() + '</div>';
  m.querySelector('.bubble').textContent = text;
  box.insertBefore(m, typing);
  box.scrollTop = box.scrollHeight;
}
async function sendMessage() {
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text) return;
  
  addMsg(text, 'user');
  input.value = '';
  const typing = document.getElementById('chatTyping');
  const box = document.getElementById('chatBox');
  typing.classList.add('on'); box.scrollTop = box.scrollHeight;
  
  const res = await apiPost(API.chat, { message: text });
  
  typing.classList.remove('on');
  addMsg(res?.reply || res?.message || 'Scarlett is thinking... let me get back to you in a tick.', 'scarlett');
}
function chipSend(el){
  document.getElementById('chatInput').value = el.textContent;
  sendMessage();
}

/* ---- Voice → GET /api/voice/voices, POST /api/voice {text, voice} → audio ---- */
async function loadVoices(){
  const d = await apiGet(API.voices);
  if(!d || !Array.isArray(d) || !d.length) return;
  document.getElementById('voiceSelect').innerHTML =
    d.map(v => `<option value="${esc(v.id||v.value||v.name)}">${esc(v.name||v.id)}</option>`).join('');
}
let currentAudio = null;
async function playVoice(){
  const text = document.getElementById('voiceText').value.trim();
  if(!text) return toast('Nothing to speak');
  const voice = document.getElementById('voiceSelect').value;
  setVoiceState('GENERATING…', true);
  try{
    const r = await fetch(API.voice, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({text, voice})
    });
    if(!r.ok) throw 0;
    const blob = await r.blob();
    currentAudio = new Audio(URL.createObjectURL(blob));
    currentAudio.onended = () => setVoiceState('READY', false);
    setVoiceState('SPEAKING', true);
    currentAudio.play();
  }catch(e){
    // Fallback: browser TTS until /api/voice is wired
    if('speechSynthesis' in window){
      speechSynthesis.cancel();
      const u = new SpeechSynthesisUtterance(text);
      u.lang = 'en-GB';
      u.onend = () => setVoiceState('READY', false);
      setVoiceState('SPEAKING (BROWSER TTS)', true);
      speechSynthesis.speak(u);
    } else {
      setVoiceState('VOICE API OFFLINE', false);
    }
  }
}
function stopVoice(){
  if(currentAudio){ currentAudio.pause(); currentAudio = null; }
  if('speechSynthesis' in window) speechSynthesis.cancel();
  setVoiceState('READY', false);
}
function setVoiceState(label, waving){
  document.getElementById('voiceStatus').textContent = label;
  document.getElementById('voiceWave').classList.toggle('on', waving);
}

/* ---- Sales Intel ---- */
async function searchCompany(){
  const q = document.getElementById('companySearch').value.trim();
  if(!q) return;
  const box = document.getElementById('companyResults');
  box.innerHTML = '<div class="placeholder">Searching Companies House…</div>';
  const d = await apiGet(API.searchCompany + '?q=' + encodeURIComponent(q));
  const items = d && (d.items || d.results || (Array.isArray(d) ? d : null));
  if(items && items.length){
    box.innerHTML = items.slice(0,6).map(c => `
      <div class="result-item">
        <div style="flex:1"><div class="cell-name">${esc(c.title||c.name)}</div>
        <div class="cell-sub">${esc(c.address||c.registered_office_address?.address_line_1||'')}</div></div>
        <span class="mono">${esc(c.company_number||c.number||'')}</span>
        <span class="pill ${ (c.company_status||c.status||'')==='active'?'qualified':'cold'}">${esc(c.company_status||c.status||'—')}</span>
      </div>`).join('');
  } else {
    // Demo result until endpoint is live
    box.innerHTML = `
      <div class="result-item">
        <div style="flex:1"><div class="cell-name">${esc(q.toUpperCase())} LTD</div>
        <div class="cell-sub">Sample result — wire /api/search-company</div></div>
        <span class="mono">0842xxxx</span>
        <span class="pill qualified">active</span>
      </div>`;
  }
}
async function enrichCompany(){
  const domain = document.getElementById('enrichInput').value.trim();
  if(!domain) return;
  const box = document.getElementById('enrichResults');
  box.innerHTML = '<div class="placeholder">Enriching via Apollo…</div>';
  const d = await apiPost(API.enrich, {domain});
  const people = d && (d.people || d.contacts || (Array.isArray(d) ? d : null));
  if(people && people.length){
    box.innerHTML = people.slice(0,6).map(p => `
      <div class="result-item">
        <div style="flex:1"><div class="cell-name">${esc(p.name)}</div>
        <div class="cell-sub">${esc(p.title||p.role||'')}</div></div>
        <span class="mono">${esc(p.email||'—')}</span>
      </div>`).join('');
  } else {
    box.innerHTML = `
      <div class="result-item">
        <div style="flex:1"><div class="cell-name">Sample Contact</div>
        <div class="cell-sub">Managing Director — wire /api/enrich</div></div>
        <span class="mono">md@${esc(domain||'company.com')}</span>
      </div>`;
  }
}
function quickEnrich(){
  const v = document.getElementById('quickEnrichInput').value.trim();
  if(!v) return;
  document.getElementById('companySearch').value = v;
  document.getElementById('enrichInput').value = v;
  searchCompany();
  enrichCompany();
  toast('Quick Enrich running on "' + v + '"');
}

/* ---- Settings: access code + API status ---- */
async function updateCode(){
  const cur = document.getElementById('currentCode').value;
  const nw  = document.getElementById('newCode').value;
  const cf  = document.getElementById('confirmCode').value;
  if(!cur || !nw)  return toast('Fill in both codes');
  if(nw !== cf)    return toast('New codes do not match');
  const res = await apiPost(API.code, {current: cur, new: nw});
  if(res && res.success){ toast('Access code updated'); }
  else if(res){ toast(res.error || 'Update failed'); }
  else { toast('Code update — wire /api/code'); }
  document.getElementById('currentCode').value = '';
  document.getElementById('newCode').value = '';
  document.getElementById('confirmCode').value = '';
}
async function loadApiStatus(){
  const d = await apiGet(API.status);
  document.querySelectorAll('#apiStatus .status-row').forEach(row => {
    const key = row.dataset.service;
    const dot = row.querySelector('.s-dot');
    const lbl = row.querySelector('.mono');
    if(d && d[key]){
      const s = String(d[key]).toLowerCase();
      dot.className = 's-dot ' + (s==='ok'||s==='up'||s==='online' ? 'ok' : s==='warn'||s==='degraded' ? 'warn' : 'down');
      lbl.textContent = String(d[key]).toUpperCase();
    } else {
      dot.className = 's-dot unknown';
      lbl.textContent = 'AWAITING BACKEND';
    }
  });
}

/* ---- Toast + escaping ---- */
/* ================= LEAD DRAWER ================= */
const LEAD_CACHE = {};
let ALL_LEADS = [];

async function viewLead(id) {
  // Find lead from cached list or API
  let lead = ALL_LEADS.find(l => l.id == id || l.company_number == id) || null;
  if (!lead && id) {
    const d = await apiGet(API.leads + (id ? '?id=eq.' + id : ''));
    if (Array.isArray(d) && d.length) lead = d[0];
  }
  if (!lead) { toast('Lead details not loaded yet'); return; }
  
  document.getElementById('drawerName').textContent = lead.contact_name || lead.name || '—';
  document.getElementById('drawerCompany').textContent = lead.company_name || lead.company || '—';
  document.getElementById('drawStatus').textContent = lead.status || '—';
  document.getElementById('drawPriority').textContent = lead.priority || '—';
  document.getElementById('drawSource').textContent = lead.source || '—';
  document.getElementById('drawValue').textContent = lead.value || '—';
  document.getElementById('drawLocation').textContent = lead.location || '—';
  document.getElementById('drawActivity').textContent = lead.lastActivity || lead.updated_at || '—';
  document.getElementById('drawEmail').textContent = lead.email || '—';
  document.getElementById('drawPhone').textContent = lead.phone || '—';
  document.getElementById('drawWebsite').textContent = lead.website || '—';
  document.getElementById('drawContact').textContent = (lead.contact_title || '') ? lead.contact_name + ' — ' + lead.contact_title : (lead.contact_name || '—');
  
  document.getElementById('leadDrawer').classList.add('open');
}
function closeLeadDrawer() {
  document.getElementById('leadDrawer').classList.remove('open');
}


/* ---- Lead Drawer Actions ---- */
let _currentLeadId = null;
async function doEnrichLead() {
  const id = _currentLeadId;
  if(!id) return toast('No lead selected');
  const btn = document.getElementById('drawerEnrichBtn');
  btn.disabled = true; btn.textContent = 'Enriching…';
  const res = await apiPost('/api/sales-intel/' + id + '/enrich', {});
  if(res && res.enriched !== false) { toast('Lead enriched ✅'); loadLeads(); }
  else { toast(res?.error || 'Enrich failed'); }
  btn.disabled = false; btn.textContent = '🔍 Enrich';
}
async function doApproveLead() {
  const id = _currentLeadId;
  if(!id) return toast('No lead selected');
  const btn = document.getElementById('drawerApproveBtn');
  btn.disabled = true; btn.textContent = 'Approving…';
  const res = await apiPost('/api/leads/' + id + '/approve', {});
  if(res && res.approved) { toast('Approved ✅'); closeLeadDrawer(); loadLeads(); }
  else { toast(res?.error || 'Approve failed'); }
  btn.disabled = false; btn.textContent = '✅ Approve';
}
async function doRejectLead() {
  const id = _currentLeadId;
  if(!id) return toast('No lead selected');
  const reason = prompt('Rejection reason (optional):');
  const btn = document.getElementById('drawerRejectBtn');
  btn.disabled = true; btn.textContent = 'Rejecting…';
  const res = await apiPost('/api/leads/' + id + '/reject', { reason: reason || '' });
  if(res && res.status === 'rejected') { toast('Rejected ❌'); closeLeadDrawer(); loadLeads(); }
  else { toast(res?.error || 'Reject failed'); }
  btn.disabled = false; btn.textContent = '❌ Reject';
}
document.addEventListener('keydown', e => {
  if(e.key === 'Escape') closeLeadDrawer();
});

let toastTimer;
function toast(msg){
  const t = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2400);
}
function esc(s){
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function setText(id, v){ const el = document.getElementById(id); if(el) el.textContent = v; }
</script>
</body>
</html>