<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GPM — Mission Control</title>
<link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0a0a0a;
  --ink-2:#141414;
  --ink-3:#1e1e1e;
  --orange:#fe5a02;
  --orange-soft:#fff0e8;
  --orange-deep:#d94b00;
  --paper:#f7f6f3;
  --card:#ffffff;
  --line:#e8e5df;
  --line-dark:rgba(255,255,255,.08);
  --text:#141414;
  --muted:#77726a;
  --faint:#a39d93;
  --green:#0f8a4c;
  --green-soft:#e7f5ec;
  --amber:#b97900;
  --amber-soft:#fdf3dd;
  --red:#c93b2b;
  --red-soft:#fdecea;
  --blue:#3757c4;
  --blue-soft:#eef2fb;
  --radius:10px;
  --sidebar-w:250px;
  --shadow:0 1px 2px rgba(10,10,10,.04), 0 4px 16px rgba(10,10,10,.05);
  --shadow-lift:0 2px 4px rgba(10,10,10,.06), 0 12px 32px rgba(10,10,10,.10);
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%}
body{
  font-family:'Inter',system-ui,sans-serif;
  background:var(--paper);
  color:var(--text);
  display:flex;
  overflow:hidden;
  font-size:14px;
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
}
button{font-family:inherit;cursor:pointer}
input,select,textarea{font-family:inherit}
:focus-visible{outline:2px solid var(--orange);outline-offset:2px;border-radius:4px}
::selection{background:var(--orange);color:#fff}

/* ============ LOGIN OVERLAY ============ */
#loginOverlay{
  position:fixed;inset:0;z-index:200;
  background:var(--ink);
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;
  transition:opacity .4s, visibility .4s;
}
#loginOverlay.hidden{opacity:0;visibility:hidden;pointer-events:none}
#loginOverlay::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, rgba(254,90,2,.10), transparent),
    radial-gradient(ellipse 40% 40% at 80% 100%, rgba(254,90,2,.05), transparent);
  pointer-events:none;
}
.login-box{
  position:relative;z-index:1;
  width:min(380px, calc(100vw - 48px));
  text-align:center;
  animation:loginIn .5s ease;
}
@keyframes loginIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
.login-box .gpm-logo{width:140px;height:auto;margin:0 auto 22px;display:block}
.login-sub{
  font-family:'IBM Plex Mono',monospace;
  font-size:10px;letter-spacing:.28em;text-transform:uppercase;
  color:var(--orange);margin:6px 0 30px;
}
.login-field{display:flex;gap:10px}
#loginCode{
  flex:1;
  background:var(--ink-3);
  border:1px solid rgba(255,255,255,.12);
  border-radius:10px;
  padding:13px 16px;
  color:#fff;
  font-family:'IBM Plex Mono',monospace;
  font-size:15px;letter-spacing:.28em;text-align:center;
  transition:border-color .15s;
}
#loginCode::placeholder{letter-spacing:.12em;color:rgba(255,255,255,.3);font-family:'Inter',sans-serif;font-size:13px}
#loginCode:focus{outline:none;border-color:var(--orange)}
#loginOverlay.shake .login-field{animation:shake .4s}
@keyframes shake{0%,100%{transform:none}20%,60%{transform:translateX(-7px)}40%,80%{transform:translateX(7px)}}
.login-btn{
  background:var(--orange);color:#fff;border:none;border-radius:10px;
  padding:13px 22px;font-size:14px;font-weight:600;
  transition:background .15s, transform .1s;
}
.login-btn:hover{background:var(--orange-deep)}
.login-btn:active{transform:scale(.97)}
#loginError{
  color:#ff7a5c;font-size:12.5px;font-weight:500;
  margin-top:14px;min-height:18px;
  opacity:0;transition:opacity .2s;
}
#loginError.show{opacity:1}

/* ============ SIDEBAR ============ */
.sidebar{
  width:var(--sidebar-w);
  flex-shrink:0;
  background:var(--ink);
  color:#fff;
  display:flex;
  flex-direction:column;
  position:relative;
  z-index:40;
}
.brand{
  padding:24px 22px 20px;
  display:flex;
  align-items:center;
  gap:13px;
  border-bottom:1px solid var(--line-dark);
}
.brand .gpm-logo{width:40px;height:auto;display:block}
.brand-name{
  font-family:'Space Grotesk',sans-serif;
  font-weight:700;
  font-size:15px;
  letter-spacing:.3em;
  text-transform:uppercase;
}
.brand-sub{
  font-family:'IBM Plex Mono',monospace;
  font-size:9px;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--orange);
  margin-top:2px;
}
.nav{flex:1;padding:10px 10px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.15) transparent}
.nav-label{
  font-family:'IBM Plex Mono',monospace;
  font-size:9px;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:rgba(255,255,255,.32);
  padding:12px 14px 6px;
}
.nav-item{
  display:flex;
  align-items:center;
  gap:11px;
  padding:8.5px 14px;
  border-radius:8px;
  color:rgba(255,255,255,.64);
  font-weight:500;
  font-size:13px;
  cursor:pointer;
  border:none;
  background:none;
  width:100%;
  text-align:left;
  position:relative;
  transition:color .15s, background .15s;
}
.nav-item svg{width:16px;height:16px;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.nav-item:hover{color:#fff;background:rgba(255,255,255,.05)}
.nav-item.active{color:#fff;background:var(--ink-3)}
.nav-item.active::before{
  content:'';
  position:absolute;
  left:0;top:8px;bottom:8px;
  width:3px;
  border-radius:2px;
  background:var(--orange);
}
.nav-item .count{
  margin-left:auto;
  font-family:'IBM Plex Mono',monospace;
  font-size:10px;
  background:var(--orange);
  color:#fff;
  padding:1px 7px;
  border-radius:20px;
  font-weight:600;
}
.sidebar-foot{
  padding:16px 22px 18px;
  border-top:1px solid var(--line-dark);
}
.sys-status{
  display:flex;align-items:center;gap:8px;
  font-family:'IBM Plex Mono',monospace;
  font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;
  color:rgba(255,255,255,.5);
}
.dot{width:7px;height:7px;border-radius:50%;background:#3ddc84;box-shadow:0 0 8px rgba(61,220,132,.8);animation:pulse 2.4s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}
.sidebar-foot .lock-btn{
  margin-top:12px;
  background:none;border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.6);
  border-radius:8px;padding:7px 12px;font-size:11.5px;font-weight:600;
  display:inline-flex;align-items:center;gap:7px;
  transition:all .15s;
}
.sidebar-foot .lock-btn:hover{border-color:var(--orange);color:#fff}
.sidebar-foot .lock-btn svg{width:12px;height:12px;stroke:currentColor;stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}

/* ============ MAIN / TOPBAR ============ */
.main{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh}
.topbar{
  height:62px;
  flex-shrink:0;
  background:var(--card);
  border-bottom:1px solid var(--line);
  display:flex;
  align-items:center;
  gap:16px;
  padding:0 24px;
}
.menu-btn{display:none;background:none;border:1px solid var(--line);border-radius:8px;width:36px;height:36px;align-items:center;justify-content:center;flex-shrink:0}
.menu-btn svg{width:18px;height:18px;stroke:var(--text);stroke-width:1.8;fill:none;stroke-linecap:round}
.page-title{
  font-family:'Space Grotesk',sans-serif;
  font-weight:700;
  font-size:16.5px;
  letter-spacing:-.01em;
}
.crumb{
  font-family:'IBM Plex Mono',monospace;
  font-size:9.5px;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--faint);
}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:14px}
.clock-wrap{text-align:right}
#clock{
  font-family:'IBM Plex Mono',monospace;
  font-size:16px;font-weight:600;letter-spacing:.05em;
  line-height:1.2;
}
#clock .sec{color:var(--orange)}
#clockDate{
  font-family:'IBM Plex Mono',monospace;
  font-size:9px;letter-spacing:.16em;text-transform:uppercase;
  color:var(--faint);
}
#topbarWeather{
  display:inline-flex;align-items:center;gap:9px;
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:10px;
  padding:7px 13px;
  font-size:13px;font-weight:600;
  transition:border-color .15s, background .15s;
}
#topbarWeather:hover{border-color:var(--orange);background:var(--orange-soft)}
#topbarWeather .w-ico{font-size:16px;line-height:1}
#topbarWeather .w-city{font-size:10.5px;font-weight:500;color:var(--muted)}
.topbar .avatar{
  width:34px;height:34px;border-radius:50%;
  background:var(--ink);color:#fff;
  font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:12px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}

.content{flex:1;overflow-y:auto;padding:26px;scroll-behavior:smooth}
.page{display:none;max-width:1240px;margin:0 auto;animation:fadeUp .28s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
@media (prefers-reduced-motion: reduce){
  *,*::before,*::after{animation:none!important;transition:none!important;scroll-behavior:auto!important}
}

/* ============ SHARED ============ */
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
}
.card-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:15px 20px;
  border-bottom:1px solid var(--line);
  gap:12px;
}
.card-title{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:14.5px}
.eyebrow{
  font-family:'IBM Plex Mono',monospace;
  font-size:10px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--muted);
}
.link-btn{
  background:none;border:none;color:var(--orange);
  font-weight:600;font-size:12.5px;
  display:inline-flex;align-items:center;gap:4px;
}
.link-btn:hover{color:var(--orange-deep)}
.pill{
  display:inline-flex;align-items:center;gap:5px;
  font-size:11.5px;font-weight:600;
  padding:3px 10px;border-radius:20px;
  white-space:nowrap;
}
.pill::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor}
.pill.new{background:var(--orange-soft);color:var(--orange-deep)}
.pill.contacted{background:var(--blue-soft);color:var(--blue)}
.pill.qualified{background:var(--green-soft);color:var(--green)}
.pill.followup{background:var(--amber-soft);color:var(--amber)}
.pill.cold{background:#f0efec;color:var(--muted)}
.pill.won{background:var(--ink);color:#fff}
.pill.todo{background:var(--blue-soft);color:var(--blue)}
.pill.progress-p{background:var(--amber-soft);color:var(--amber)}
.pill.done{background:var(--green-soft);color:var(--green)}
.pill.blocked{background:var(--red-soft);color:var(--red)}
.pill.live{background:var(--green-soft);color:var(--green)}
.pill.draft{background:#f0efec;color:var(--muted)}
.pill.sched{background:var(--amber-soft);color:var(--amber)}
.prio{font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:600;letter-spacing:.08em}
.prio.high{color:var(--red)}
.prio.med{color:var(--amber)}
.prio.low{color:var(--faint)}
.mono{font-family:'IBM Plex Mono',monospace;font-size:12px}
.primary-btn{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--orange);color:#fff;border:none;
  font-weight:600;font-size:13px;
  padding:9px 16px;border-radius:8px;
  transition:background .15s, transform .1s;
}
.primary-btn:hover{background:var(--orange-deep)}
.primary-btn:active{transform:scale(.98)}
.primary-btn svg{width:14px;height:14px;stroke:#fff;stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}
.dark-btn{
  background:var(--ink);color:#fff;border:none;border-radius:8px;
  padding:9px 16px;font-size:13px;font-weight:600;
  transition:background .15s;
  display:inline-flex;align-items:center;gap:7px;
}
.dark-btn:hover{background:var(--ink-3)}
.ghost-btn{
  display:inline-flex;align-items:center;gap:6px;
  border:1px solid var(--line);background:#fff;border-radius:8px;
  padding:7px 13px;font-size:12.5px;font-weight:600;color:var(--text);
  transition:border-color .15s;
}
.ghost-btn:hover{border-color:var(--faint)}
.ghost-btn svg{width:14px;height:14px;stroke:currentColor;stroke-width:1.8;fill:none;stroke-linecap:round}
.toolbar{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.toolbar .spacer{flex:1}
.tabs{display:inline-flex;background:#fff;border:1px solid var(--line);border-radius:8px;padding:3px;gap:2px}
.tab{
  border:none;background:none;border-radius:6px;
  padding:6px 14px;font-size:12.5px;font-weight:600;color:var(--muted);
  transition:all .15s;
}
.tab:hover{color:var(--text)}
.tab.active{background:var(--ink);color:#fff}
table{width:100%;border-collapse:collapse}
th{
  font-family:'IBM Plex Mono',monospace;
  font-size:10px;letter-spacing:.16em;text-transform:uppercase;
  color:var(--muted);font-weight:500;
  text-align:left;padding:12px 16px;
  border-bottom:1px solid var(--line);
  white-space:nowrap;
}
td{padding:12px 16px;border-bottom:1px solid var(--line);font-size:13px;vertical-align:middle}
tbody tr{transition:background .12s}
tbody tr:hover{background:var(--paper)}
tbody tr:last-child td{border-bottom:none}
.cell-name{font-weight:600;font-size:13px}
.cell-sub{font-size:11.5px;color:var(--muted)}
.table-scroll{overflow-x:auto}
.empty-row td{text-align:center;color:var(--faint);padding:28px;font-size:12.5px}

/* ============ DASHBOARD ============ */
.greeting{margin-bottom:22px}
.greeting h1{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:700;letter-spacing:-.02em}
.greeting p{color:var(--muted);margin-top:3px;font-size:13.5px}
.greeting .hl{color:var(--orange-deep);font-weight:600}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}
.kpi{padding:17px 19px 15px}
.kpi .eyebrow{display:block;margin-bottom:9px}
.kpi-row{display:flex;align-items:flex-end;justify-content:space-between;gap:8px}
.kpi-num{font-family:'Space Grotesk',sans-serif;font-size:31px;font-weight:700;line-height:1;letter-spacing:-.02em}
.kpi svg.spark{width:72px;height:28px;flex-shrink:0}
.delta{display:inline-flex;align-items:center;gap:3px;font-size:11.5px;font-weight:600;margin-top:9px}
.delta.up{color:var(--green)}
.delta.down{color:var(--red)}
.delta span{color:var(--faint);font-weight:500}
.feed-item{display:flex;gap:12px;padding:12px 20px;border-bottom:1px solid var(--line)}
.feed-item:last-child{border-bottom:none}
.feed-ico{
  width:30px;height:30px;border-radius:8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
}
.feed-ico svg{width:15px;height:15px;stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round}
.feed-txt{font-size:12.5px;line-height:1.45}
.feed-txt b{font-weight:600}
.feed-time{font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:var(--faint);margin-top:2px}

/* ============ SALES INTEL ============ */
.intel-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;margin-bottom:16px}
.intel-card{padding:20px}
.intel-card h3{font-family:'Space Grotesk',sans-serif;font-size:14.5px;font-weight:600;margin-bottom:3px}
.intel-card .eyebrow{display:block;margin-bottom:15px}
.search-row{display:flex;gap:9px}
.search-row input{
  flex:1;border:1px solid var(--line);border-radius:8px;
  padding:10px 13px;font-size:13px;background:#fff;
}
.search-row input:focus{outline:none;border-color:var(--orange)}
.result-box{
  margin-top:14px;
  border:1px dashed var(--line);
  border-radius:8px;
  min-height:88px;
  padding:12px;
  font-size:12.5px;color:var(--faint);
  display:flex;flex-direction:column;gap:8px;
}
.result-box .placeholder{margin:auto;text-align:center}
.result-item{
  border:1px solid var(--line);background:var(--paper);
  border-radius:8px;padding:10px 13px;
  display:flex;align-items:center;gap:11px;
  color:var(--text);
}
.result-item .cell-name{flex:1}
.result-item .mono{color:var(--muted)}
.quick-enrich{
  background:var(--ink);color:#fff;border:none;
  border-radius:var(--radius);padding:20px;
  display:flex;gap:16px;align-items:center;flex-wrap:wrap;
}
.quick-enrich .qe-txt{flex:1;min-width:220px}
.quick-enrich h3{font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:600}
.quick-enrich p{font-size:12.5px;color:rgba(255,255,255,.7);margin-top:3px}
.quick-enrich input{
  background:var(--ink-3);border:1px solid rgba(255,255,255,.14);
  border-radius:8px;padding:10px 13px;color:#fff;font-size:13px;
  width:240px;
}
.quick-enrich input:focus{outline:none;border-color:var(--orange)}

/* ============ BRIEFING ============ */
.brief-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:16px;align-items:start}
.brief-hero{
  background:var(--ink);color:#fff;border:none;
  border-radius:var(--radius);
  padding:24px;
  margin-bottom:16px;
}
.brief-hero .eyebrow{color:var(--orange);display:block;margin-bottom:8px}
.brief-hero h2{font-family:'Space Grotesk',sans-serif;font-size:21px;font-weight:700;letter-spacing:-.01em}
.brief-weather-strip{
  display:flex;gap:22px;margin-top:16px;padding-top:16px;
  border-top:1px solid var(--line-dark);
  flex-wrap:wrap;
}
.bw-item .mono{color:rgba(255,255,255,.55);font-size:10px;letter-spacing:.14em;text-transform:uppercase}
.bw-item b{font-family:'Space Grotesk',sans-serif;font-size:17px;display:block;margin-top:2px}
#briefingContent{padding:20px;font-size:13.5px;line-height:1.65}
#briefingContent p{margin-bottom:12px}
#briefingContent p:last-child{margin-bottom:0}
#briefingContent b{font-weight:600}
.headline{display:flex;gap:12px;padding:13px 20px;border-bottom:1px solid var(--line)}
.headline:last-child{border-bottom:none}
.headline .h-src{
  font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--orange-deep);flex-shrink:0;width:74px;padding-top:2px;
}
.headline p{font-size:13px;font-weight:500;line-height:1.45}
.headline span{font-size:11px;color:var(--faint);display:block;margin-top:2px}

/* ============ CALENDAR (list) ============ */
.cal-day{padding:0}
.cal-day-head{
  display:flex;align-items:baseline;gap:10px;
  padding:13px 20px;
  background:var(--paper);
  border-bottom:1px solid var(--line);
}
.cal-day-head b{font-family:'Space Grotesk',sans-serif;font-size:13.5px;font-weight:600}
.cal-day-head .eyebrow{letter-spacing:.14em}
.cal-evt{display:flex;align-items:center;gap:14px;padding:13px 20px;border-bottom:1px solid var(--line)}
.cal-evt:last-child{border-bottom:none}
.cal-evt .time{font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;width:88px;flex-shrink:0}
.cal-evt .bar{width:3px;height:30px;border-radius:2px;flex-shrink:0}
.cal-evt .cell-name{font-size:13px}
.cal-evt .cell-sub{margin-top:1px}

/* ============ APPROVALS ============ */
.approval{padding:18px 20px;display:flex;gap:16px;align-items:center;flex-wrap:wrap;margin-bottom:12px}
.approval .lead-avatar{
  width:40px;height:40px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:13px;font-family:'Space Grotesk',sans-serif;
  background:var(--orange-soft);color:var(--orange-deep);
}
.approval .ap-body{flex:1;min-width:220px}
.approval .cell-sub{margin-top:1px}
.ap-reason{
  font-size:12.5px;color:var(--muted);margin-top:7px;
  padding:8px 11px;background:var(--paper);border-radius:7px;
  border-left:2px solid var(--orange);
}
.ap-actions{display:flex;gap:8px}
.approve-btn{
  background:var(--green);color:#fff;border:none;border-radius:8px;
  padding:8px 15px;font-size:12.5px;font-weight:600;
}
.approve-btn:hover{background:#0c7340}
.reject-btn{
  background:#fff;border:1px solid var(--line);color:var(--red);
  border-radius:8px;padding:8px 15px;font-size:12.5px;font-weight:600;
}
.reject-btn:hover{border-color:var(--red);background:var(--red-soft)}

/* ============ CHAT ============ */
.chat-shell{display:grid;grid-template-columns:1fr 290px;gap:16px;align-items:start}
.chat-card{display:flex;flex-direction:column;height:calc(100vh - 156px);min-height:460px}
.chat-header{display:flex;align-items:center;gap:12px;padding:15px 20px;border-bottom:1px solid var(--line)}
.scarlett-avatar{
  width:40px;height:40px;border-radius:50%;
  background:var(--orange);color:#fff;
  font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:16px;
  display:flex;align-items:center;justify-content:center;
  position:relative;flex-shrink:0;
}
.scarlett-avatar::after{
  content:'';position:absolute;bottom:0;right:0;
  width:11px;height:11px;border-radius:50%;
  background:#3ddc84;border:2px solid #fff;
}
.chat-header h3{font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:600}
.chat-body{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:4px;background:var(--paper)}
.msg{max-width:74%;display:flex;flex-direction:column;margin-bottom:10px}
.msg.user{align-self:flex-end;align-items:flex-end}
.msg.scarlett{align-self:flex-start;align-items:flex-start}
.bubble{padding:10px 14px;border-radius:14px;font-size:13.5px;line-height:1.5}
.msg.scarlett .bubble{background:#fff;border:1px solid var(--line);border-bottom-left-radius:4px}
.msg.user .bubble{background:var(--ink);color:#fff;border-bottom-right-radius:4px}
.msg-time{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--faint);margin-top:4px;padding:0 4px}
.typing{display:none;align-self:flex-start;background:#fff;border:1px solid var(--line);border-radius:14px;border-bottom-left-radius:4px;padding:12px 16px;margin-bottom:10px}
.typing.on{display:flex;gap:4px}
.typing i{width:6px;height:6px;border-radius:50%;background:var(--faint);animation:blink 1.2s infinite}
.typing i:nth-child(2){animation-delay:.2s}
.typing i:nth-child(3){animation-delay:.4s}
@keyframes blink{0%,80%,100%{opacity:.25}40%{opacity:1}}
.chips{display:flex;gap:8px;flex-wrap:wrap;padding:12px 20px 0}
.chip{
  border:1px solid var(--line);background:#fff;
  border-radius:20px;padding:6px 13px;
  font-size:12px;font-weight:500;color:var(--muted);
  transition:all .15s;
}
.chip:hover{border-color:var(--orange);color:var(--orange-deep);background:var(--orange-soft)}
.chat-input-row{display:flex;gap:10px;padding:14px 20px 18px}
.chat-input-row input{
  flex:1;border:1px solid var(--line);border-radius:8px;
  padding:11px 14px;font-size:13.5px;background:#fff;
}
.chat-input-row input:focus{outline:none;border-color:var(--orange)}
.send-btn{
  background:var(--orange);border:none;border-radius:8px;
  width:44px;display:flex;align-items:center;justify-content:center;
  transition:background .15s, transform .1s;flex-shrink:0;
}
.send-btn:hover{background:var(--orange-deep)}
.send-btn:active{transform:scale(.95)}
.send-btn svg{width:17px;height:17px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.side-stat{display:flex;justify-content:space-between;align-items:center;padding:11px 20px;border-bottom:1px solid var(--line);font-size:12.5px}
.side-stat:last-child{border-bottom:none}
.side-stat b{font-family:'IBM Plex Mono',monospace;font-size:12.5px}
.cap{display:flex;gap:10px;align-items:center;padding:9px 20px;font-size:12.5px;color:var(--muted)}
.cap svg{width:14px;height:14px;stroke:var(--orange-deep);stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.cap-list{padding:6px 0}

/* ============ VOICE ============ */
.voice-wrap{max-width:640px}
.voice-card{padding:24px}
.voice-card h3{font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:600;margin-bottom:3px}
.voice-card .eyebrow{display:block;margin-bottom:18px}
.field{margin-bottom:16px}
.field label{display:block;font-size:12px;font-weight:600;margin-bottom:6px}
.field input,.field select,.field textarea{
  width:100%;border:1px solid var(--line);border-radius:8px;
  padding:10px 12px;font-size:13px;background:#fff;
}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--orange)}
.field textarea{resize:vertical;line-height:1.55}
.voice-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
#voiceStatus{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted)}
.wave{
  display:none;align-items:flex-end;gap:3px;height:22px;
}
.wave.on{display:flex}
.wave i{width:3px;background:var(--orange);border-radius:2px;animation:wave 1s ease-in-out infinite}
.wave i:nth-child(1){height:40%;animation-delay:0s}
.wave i:nth-child(2){height:90%;animation-delay:.15s}
.wave i:nth-child(3){height:60%;animation-delay:.3s}
.wave i:nth-child(4){height:100%;animation-delay:.45s}
.wave i:nth-child(5){height:50%;animation-delay:.6s}
@keyframes wave{0%,100%{transform:scaleY(.4)}50%{transform:scaleY(1)}}

/* ============ SETTINGS ============ */
.set-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;align-items:start}
.set-section{padding:20px}
.set-section h3{font-family:'Space Grotesk',sans-serif;font-size:14.5px;font-weight:600;margin-bottom:3px}
.set-section .eyebrow{margin-bottom:16px;display:block}
.status-row{display:flex;align-items:center;gap:11px;padding:11px 0;border-bottom:1px solid var(--line);font-size:13px}
.status-row:last-child{border-bottom:none}
.status-row .s-name{flex:1;font-weight:600}
.status-row .s-sub{font-size:11px;color:var(--muted);font-weight:400;display:block}
.s-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.s-dot.ok{background:var(--green);box-shadow:0 0 6px rgba(15,138,76,.5)}
.s-dot.warn{background:var(--amber)}
.s-dot.down{background:var(--red)}
.s-dot.unknown{background:var(--faint)}
.status-row .mono{color:var(--muted);font-size:11px}

/* ============ LEAD DRAWER ============ */
.drawer-overlay{
  position:fixed;inset:0;z-index:140;
  background:rgba(10,10,10,0.6);backdrop-filter:blur(4px);
  display:flex;justify-content:flex-end;
  opacity:0;visibility:hidden;
  transition:opacity .25s, visibility .25s;
}
.drawer-overlay.open{opacity:1;visibility:visible}
.drawer-panel{
  width:420px;max-width:92vw;height:100%;
  background:var(--card);border-left:1px solid var(--line);
  padding:28px 24px;overflow-y:auto;
  transform:translateX(30px);
  transition:transform .3s ease;
}
.drawer-overlay.open .drawer-panel{transform:translateX(0)}
.drawer-close{
  background:none;border:1px solid var(--line);border-radius:50%;
  width:36px;height:36px;font-size:14px;color:var(--muted);
  cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;margin-left:auto;
}
.drawer-close:hover{border-color:var(--orange);color:var(--orange)}
.drawer-header{margin-bottom:28px}
.drawer-header .eyebrow{margin-bottom:8px}
.drawer-name{font-size:22px;font-weight:700;color:var(--ink);margin-bottom:4px}
.drawer-company{font-size:14px;color:var(--muted)}
.drawer-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.dg-item{display:flex;flex-direction:column;gap:3px}
.dg-item.full{grid-column:1/-1}
.dg-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--faint)}
.dg-value{font-size:14px;color:var(--ink);font-weight:500;word-break:break-word}
.drawer-actions{display:flex;gap:10px;margin-top:24px;padding-top:20px;border-top:1px solid var(--line)}
.drawer-actions .btn{flex:1;justify-content:center;padding:10px 0;font-size:13px}
.btn-outline{background:none;border:1px solid var(--line);border-radius:8px;color:var(--ink);cursor:pointer;display:flex;align-items:center;gap:6px;font-weight:500;transition:all .15s}
.btn-outline:hover{border-color:var(--orange);color:var(--orange)}

/* ============ WEATHER OVERLAY ============ */
#weatherOverlay{
  position:fixed;inset:0;z-index:150;
  background:var(--ink);
  color:#fff;
  display:flex;align-items:center;justify-content:center;
  opacity:0;visibility:hidden;
  transition:opacity .3s, visibility .3s;
}
#weatherOverlay.open{opacity:1;visibility:visible}
#weatherOverlay::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 55% at 50% -10%, rgba(254,90,2,.14), transparent);
  pointer-events:none;
}
.weather-close{
  position:absolute;top:24px;right:28px;
  background:var(--ink-3);border:1px solid rgba(255,255,255,.14);
  color:#fff;border-radius:50%;
  width:42px;height:42px;font-size:17px;
  transition:all .15s;z-index:2;
}
.weather-close:hover{border-color:var(--orange);color:var(--orange)}
.weather-panel{position:relative;z-index:1;text-align:center;padding:24px;max-width:560px;width:100%}
.weather-panel .eyebrow{color:var(--orange);letter-spacing:.28em}
#wCity{font-family:'Space Grotesk',sans-serif;font-size:22px;font-weight:700;margin-top:8px}
#wIcon{font-size:64px;margin:18px 0 4px;line-height:1}
#wTemp{font-family:'Space Grotesk',sans-serif;font-size:76px;font-weight:700;letter-spacing:-.03em;line-height:1}
#wCondition{font-size:15px;color:rgba(255,255,255,.75);margin-top:6px}
#wFeels{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-top:4px}
.weather-stats{
  display:grid;grid-template-columns:repeat(3,1fr);gap:12px;
  margin-top:34px;
}
.w-stat{
  background:var(--ink-3);border:1px solid rgba(255,255,255,.09);
  border-radius:12px;padding:16px 12px;
}
.w-stat .mono{font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.w-stat b{font-family:'Space Grotesk',sans-serif;font-size:21px;font-weight:700;display:block;margin-top:5px}
.w-stat span{font-size:11px;color:rgba(255,255,255,.5)}

/* ============ LEAD DRAWER ============ */
.drawer{
  position:fixed;inset:0;z-index:180;
  display:flex;
  opacity:0;visibility:hidden;
  transition:opacity .25s, visibility .25s;
}
.drawer.open{opacity:1;visibility:visible}
.drawer-backdrop{
  position:absolute;inset:0;
  background:rgba(10,10,10,.45);
}
.drawer-panel{
  position:absolute;right:0;top:0;bottom:0;
  width:min(480px,calc(100vw - 48px));
  background:var(--card);
  border-left:1px solid var(--line);
  box-shadow:-8px 0 32px rgba(10,10,10,.12);
  display:flex;flex-direction:column;
  transform:translateX(24px);
  transition:transform .25s ease;
}
.drawer.open .drawer-panel{transform:none}
.drawer-head{
  display:flex;align-items:flex-start;justify-content:space-between;
  padding:22px 24px 14px;border-bottom:1px solid var(--line);gap:16px;
}
.drawer-close{
  background:none;border:1px solid var(--line);border-radius:8px;
  width:36px;height:36px;font-size:16px;color:var(--muted);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .15s;
}
.drawer-close:hover{border-color:var(--orange);color:var(--orange)}
.drawer-body{flex:1;overflow-y:auto;padding:18px 24px 80px}
.drawer-section{margin-bottom:22px}
.drawer-section .eyebrow{display:block;margin-bottom:10px}
.drawer-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.drawer-grid div{
  background:var(--paper);border-radius:8px;
  padding:9px 12px;font-size:13px;
}
.drawer-grid span.mono{display:block;font-size:10px;color:var(--muted);margin-bottom:3px}

/* ============ TOAST ============ */
.toast{
  position:fixed;bottom:24px;right:24px;z-index:300;
  background:var(--ink);color:#fff;
  padding:12px 18px;border-radius:10px;
  font-size:13px;font-weight:500;
  display:flex;align-items:center;gap:10px;
  box-shadow:var(--shadow-lift);
  transform:translateY(80px);opacity:0;
  transition:transform .3s cubic-bezier(.2,.9,.3,1.2), opacity .3s;
  pointer-events:none;
}
.toast.show{transform:none;opacity:1}
.toast i{width:7px;height:7px;border-radius:50%;background:var(--orange);flex-shrink:0}

/* ============ RESPONSIVE ============ */
.overlay-dim{display:none;position:fixed;inset:0;background:rgba(10,10,10,.5);z-index:35}
@media (max-width:1100px){
  .kpis{grid-template-columns:repeat(2,1fr)}
  .chat-shell,.intel-grid,.brief-grid,.set-grid{grid-template-columns:1fr}
  .chat-card{height:60vh}
}
@media (max-width:820px){
  .sidebar{position:fixed;left:0;top:0;bottom:0;transform:translateX(-100%);transition:transform .25s ease}
  .sidebar.open{transform:none}
  .overlay-dim.show{display:block}
  .menu-btn{display:inline-flex}
  .content{padding:16px}
  .kpis{gap:10px}
  .clock-wrap{display:none}
  #topbarWeather .w-city{display:none}
  .weather-stats{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>

<!-- ================= LOGIN ================= -->
<div id="loginOverlay">
  <div class="login-box">
    <img class="gpm-logo" src="logo_2.png" alt="Darren Pelling">
    <div class="login-sub">Restricted Access</div>
    <div class="login-field">
      <input type="password" id="loginCode" placeholder="Access code" autocomplete="off"
             onkeydown="if(event.key==='Enter')attemptLogin()" aria-label="Access code">
      <button class="login-btn" onclick="attemptLogin()">Enter</button>
    </div>
    <div id="loginError" role="alert">Invalid code</div>
  </div>
</div>

<div class="overlay-dim" id="overlayDim" onclick="toggleSidebar(false)"></div>

<!-- ================= SIDEBAR ================= -->
<aside class="sidebar" id="sidebar">
  <div class="brand">
    <img class="gpm-logo" src="logo_2.png" alt="DP logo">
    <div>
      <div class="brand-name">GPM</div>
      <div class="brand-sub">Mission Control</div>
    </div>
  </div>

  <nav class="nav" aria-label="Main navigation">
    <div class="nav-label">Operations</div>
    <button class="nav-item active" data-page="dashboard" onclick="nav('dashboard',this)">
      <svg viewBox="0 0 24 24"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M10 21v-6h4v6"/></svg>
      Dashboard
    </button>
    <button class="nav-item" data-page="leads" onclick="nav('leads',this)">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Leads
      <span class="count" id="navLeadsCount">23</span>
    </button>
    <button class="nav-item" data-page="tasks" onclick="nav('tasks',this)">
      <svg viewBox="0 0 24 24"><path d="M9 11.5 11 13.5 15 9.5"/><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M8 2v4M16 2v4"/></svg>
      Tasks
      <span class="count" id="navTasksCount">5</span>
    </button>
    <button class="nav-item" data-page="campaigns" onclick="nav('campaigns',this)">
      <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6L22 7"/></svg>
      Campaigns
    </button>
    <button class="nav-item" data-page="sales-intel" onclick="nav('sales-intel',this)">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>
      Sales Intel
    </button>
    <div class="nav-label">Intelligence</div>
    <button class="nav-item" data-page="briefing" onclick="nav('briefing',this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      Daily Briefing
    </button>
    <button class="nav-item" data-page="calendar" onclick="nav('calendar',this)">
      <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      Calendar
    </button>
    <button class="nav-item" data-page="approvals" onclick="nav('approvals',this)">
      <svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
      Approvals
      <span class="count" id="navApprovalsCount">3</span>
    </button>
    <div class="nav-label">Scarlett</div>
    <button class="nav-item" data-page="chat" onclick="nav('chat',this)">
      <svg viewBox="0 0 24 24"><path d="M21 12a8 8 0 0 1-8 8H4l2-3a8 8 0 1 1 15-5z"/></svg>
      Chat
    </button>
    <button class="nav-item" data-page="voice" onclick="nav('voice',this)">
      <svg viewBox="0 0 24 24"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><path d="M12 17v4"/></svg>
      Voice
    </button>
    <div class="nav-label">System</div>
    <button class="nav-item" data-page="settings" onclick="nav('settings',this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Settings
    </button>
  </nav>

  <div class="sidebar-foot">
    <div class="sys-status"><span class="dot"></span> Scarlett online</div>
    <button class="lock-btn" onclick="lockApp()">
      <svg viewBox="0 0 24 24"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
      Lock
    </button>
  </div>
</aside>

<!-- ================= MAIN ================= -->
<div class="main">
  <header class="topbar">
    <button class="menu-btn" onclick="toggleSidebar(true)" aria-label="Open menu">
      <svg viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
    <div>
      <div class="crumb" id="crumb">OPS / 01</div>
      <div class="page-title" id="pageTitle">Dashboard</div>
    </div>
    <div class="topbar-right">
      <button id="topbarWeather" onclick="toggleWeatherApp()" aria-label="Open weather">
        <span class="w-ico" id="topbarWeatherIcon">☀️</span>
        <span id="topbarWeatherTemp">21°</span>
        <span class="w-city" id="topbarWeatherCity">Madrid</span>
      </button>
      <div class="clock-wrap">
        <div id="clock">00:00<span class="sec">:00</span></div>
        <div id="clockDate">—</div>
      </div>
      <div class="avatar" title="GPM">DP</div>
    </div>
  </header>

  <div class="content" id="content">

    <!-- ============ 1. DASHBOARD ============ -->
    <section id="page-dashboard" class="page active">
      <div class="greeting">
        <h1 id="greet">Good morning</h1>
        <p>Scarlett processed <span class="hl">14 new activities</span> overnight. Here's where things stand.</p>
      </div>

      <div class="kpis">
        <div class="card kpi">
          <span class="eyebrow">Leads</span>
          <div class="kpi-row">
            <span class="kpi-num" id="statLeads">23</span>
            <svg class="spark" viewBox="0 0 72 28" preserveAspectRatio="none"><polyline points="0,22 12,18 24,20 36,13 48,15 60,7 72,4" fill="none" stroke="#fe5a02" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <span class="delta up">▲ 12% <span>vs last week</span></span>
        </div>
        <div class="card kpi">
          <span class="eyebrow">Emails sent</span>
          <div class="kpi-row">
            <span class="kpi-num" id="statEmails">147</span>
